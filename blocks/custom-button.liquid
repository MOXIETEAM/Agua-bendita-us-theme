{% liquid
  assign effect = 'hdt-reveal="slide-in" timeline'
  if section.id contains 'slideshow'
    assign effect = 'reval'
  endif   

  assign is_link = false
  if block.settings.behaviour == "open_link"
    assign is_link = true
  endif

  assign tag = "a"
  unless is_link
    assign tag = "button"
  endunless
%}
<{{ tag }} {{ effect }} id="block-{{ block.id }}" {% if block.settings.link == blank and is_link %}role="link" aria-disabled="true"{% elsif is_link %}href="{{ block.settings.link }}"{% endif %} class="hdt-button-block hdt-btn hdt-relative hdt-oh hdt-font-{{ block.settings.font_weight }} hdt-btn--size-{{ block.settings.font_size }} hdt-btn-{{ block.settings.style_class }}{% if block.settings.full_width %} hdt-btn-full-width{% endif %}{% if block.settings.icon != "none" %} hdt-btn--with-icon  hdt-btn--pos-icon-{{ block.settings.icon_position }}{% endif %}"{% if block.settings.icon != "none" %} style="--gap-btn-icon: {{ block.settings.icon_spacing }}px; --height-btn-icon: {{ block.settings.icon_height }}px"{% endif %} {% if block.settings.open_in_new_tab %} target="_blank" rel="noopener noreferrer"{% endif -%} {{ block.shopify_attributes }}>

<i class="hdt-custom-icon-drop-right"></i>
  {%- liquid
  if block.settings.icon != 'none'
    render 'icons', icon: block.settings.icon
  endif
  echo block.settings.label
  -%}
</{{ tag }}>
{%- if block.settings.font_size == "custom custom-inline" -%}
  {%- style -%}
    #block-{{ block.id }} {
      --padding-button: 5px {{ block.settings.padding_btn }}px; --height-button: {{ block.settings.min_height_btn }}px; --font-size-button: {{ block.settings.font_size_btn }}px;--min-width-btn: {{ block.settings.min_width_btn }}px; --min-width-btn-dt: {{ block.settings.min_width_dt_btn }}px;
    }
  {%- endstyle -%}
{%- endif -%}
