{%- liquid
  unless product
    assign product = section.settings.product
  endunless
-%}
{%- unless block.settings.title == blank or product.description == blank -%}
  <!--item-title>
  <button aria-current="{%- if block.settings.open %}true{% else %}false{% endif %}" class="hdt-s-text hdt-relative hdt-font-semibold">{{ block.settings.title | escape }}</button>
  -->
  <div class="hdt-tab-item hdt-rte" tab-item {%- if block.settings.open %} tab-selected{% endif %} data-type={{ block.type }} {{ block.shopify_attributes }}>
    {{- product.description -}}
  </div>
{%- endunless -%}
{% schema %}
{
  "name": "Description",
  "tag": null,
  "settings": [
    {
      "type": "checkbox",
      "id": "open",
      "label": "Open by default",
      "default": false
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.main-product-tabs.blocks.title.label",
      "default": "Description"
    }
  ],
  "presets": [
    {
      "name": "Description"
    }
  ]
}
{% endschema %}
