<!-- blocks/banner-item.liquid -->
{%- liquid
  assign image_height = block.settings.image_height | default: "adapt_image"
  assign image_height_mb = block.settings.image_height_mb | default: "adapt_image"

-%}
<div id="{{ block.id }}" class="hdt-banner__item hdt-slider__slide md:hdt-height--{{ image_height }} hdt-height--{{ image_height_mb }} hdt-eff-{{ block.settings.b_effect }} hdt-eff-img-{{ block.settings.img_effect }} hdt-eff hdt-oh hdt-relative" color-scheme="{{ block.settings.color_scheme }}" {{ block.shopify_attributes }}>
  {%- liquid
    assign object_pos = block.settings.image_mb.presentation.focal_point
  -%}
  <div class="hdt-item_inner hdt-media-overlap-content" style="{% if image_height_mb == 'adapt_image' %}{% assign image_mb = block.settings.image_mb | default: block.settings.image %}--aspect-ratioapt: {{ image_mb.aspect_ratio | default: 2.0 }};{% endif %}{% if image_height == 'adapt_image' %}--aspect-ratioapt-md: {{ block.settings.image.aspect_ratio | default: 2.0 }};{% endif %}{% if object_pos != blank %}--object-pos-mb: {{ object_pos }}{% endif %}" hdt-reveal="slide-in" timeline>
    <a class="hdt-full-width-link" {%- if block.settings.banner_url == blank %} role="link" disabled="true" {%- else %} href="{{ block.settings.banner_url }}"{% endif %} target="{% if block.settings.banner_target %}_blank{% else %}_self{% endif %}"></a>
    {% content_for 'block', type: '_custom-media', id: 'banner-media' %}
    <div class="hdt-grid hdt-h-full hdt-pe-none ">
      <div class="hdt-place-self-{{ block.settings.content_position_mb }} md:hdt-place-self-{{ block.settings.content_position }} {% if block.settings.background_content %} hdt-background-content{% endif %}{% if block.settings.use_border_content %} hdt-content-use-border{% endif %}{% if block.settings.box_square %} hdt-content-boxsquare{% endif %}{% if block.settings.content_rounded %} hdt-rounded-full{% endif %}"{% if block.settings.background_content %} style="--content-bg-opacity: {{ block.settings.bg_opacity | divided_by: 100.00 }};--content-border-opacity: {{ block.settings.border_opacity | divided_by: 100.00 }};--content-border-style: {{ block.settings.border_style }};--border-pd-dk: {{ block.settings.border_pd_dk }}px;--border-pd-mb: {{ block.settings.border_pd }}px;" {% endif %}>
        <div class="hdt-content hdt-text-{{ block.settings.alignment_mb }} md:hdt-text-{{ block.settings.alignment }}">
          {% content_for "blocks" %}
        </div>
      </div>
    </div>
  </div>
</div>
