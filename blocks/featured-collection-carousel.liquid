        },
        {
          "label": "3",
          "value": "3"
        },
        {
          "label": "4",
          "value": "4"
        }
      ]
    },
    {
      "type": "select",
      "id": "col_mb",
      "label": "t:sections.all.items_row.mobile",
      "default": "2",
      "options": [
        {
          "label": "1",
          "value": "1"
        },
        {
          "label": "2",
          "value": "2"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "half_item",
      "label": "t:sections.all.slider.half_item.label",
      "info": "t:sections.all.slider.half_item.info",
      "default": false
    },
    {
      "type": "header",
      "content": "Slider configs"
    },
