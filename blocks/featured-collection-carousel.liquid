<!-- featured-collection-carousel.liquid -->
{%- comment -%}{{ 'hdt-card-products.css' | asset_url | stylesheet_tag }}{%- endcomment -%}
{% liquid
  if block.settings.active_from != blank
    assign from_dt = block.settings.active_from | date: "%s" | plus: 0
  else
    assign from_dt = 'now' | date: '%s' | minus: 1
  endif

  if block.settings.active_to != blank
    assign to_dt = block.settings.active_to | date: "%s" | plus: 0
  else
    assign to_dt = 'now' | date: '%s' | plus: 1
  endif

  assign now_dt = "now" | date: "%s" | plus: 0
%}

{% if from_dt <= now_dt and now_dt <= to_dt %}
  {%- liquid
    assign current_width = settings.page_width | append: 'px'
    assign current_width_tb = '100vw'
    assign current_width_mb = '100vw'
    assign space_item = "30px"
    assign space_item_tb = "15px"
    assign space_item_mb = "15px" 

    if block.settings.section_fullwidth
      if block.settings.boxed_fullwidth
        assign current_width = '100vw - 80px'
        assign current_width_tb = '100vw - 40px'
        assign current_width_mb = '100vw - 10px'
      else
        assign current_width = '100vw'
      endif
    endif
    assign product_collection = block.settings.product_list | default: block.settings.collection.products
    assign color_list = 'products.theme_settings.color' | t | downcase | strip | replace: ' ,', ',' | replace: ', ', ',' | split: ',' | uniq
    assign size_list = 'products.theme_settings.size' | t | downcase | strip | replace: ' ,', ',' | replace: ', ', ',' | split: ',' | uniq 
    assign navUI = false
    if block.settings.navUI or block.settings.nav_heading != "disable"
      assign navUI = true
    endif

  -%}

  {%- capture sizes -%}
    (min-width: 1150px) calc(({{ current_width }} -  ({{ space_item }} * ( {{ block.settings.col_dk }} - 1 ))) * 1 / {{ block.settings.col_dk }}),(min-width: 768px) calc( ({{ current_width_tb }} - ({{ space_item_tb }} * ( {{ block.settings.col_tb }} - 1 ))) * 1 / {{ block.settings.col_tb }}), calc( ({{ current_width_mb }} - ({{ space_item_mb }} * ( {{ block.settings.col_mb }} - 1 ) )) * 1 / {{ block.settings.col_mb }})
  {%- endcapture -%}
  {%- style -%}.hdt-has-bg-img{position:relative}.hdt-has-bg-img .hdt-section-bg-img{z-index:0}.hdt-has-bg-img .hdt-section-bg-img img{width:100%;height:100%;object-fit:cover;object-position:center}@media(max-width:1149px){.hdt-container-full.lg\:hdt-ps-max{max-width:var(--container-max-width-padding-md);padding-inline-start:3rem}}@media(max-width:767px){.hdt-container-full.lg\:hdt-ps-max{max-width:100vw;padding-inline-start:1.5rem}}

    @media(min-width: 1150px) {
      #{{ block.id }} {
        --spacing-x: {{ block.settings.horizontal_space_bt_items }}px;
        --spacing-y: {{ block.settings.vertical_space_bt_items }}px;
        padding-left: {{ block.settings.padding_left }}px;
        padding-right: {{ block.settings.padding_right }}px;
      }
    }
    @media(max-width: 1149px) {
      #{{ block.id }} {
        --spacing-x: {{ block.settings.horizontal_space_bt_items_mb }}px;
        --spacing-y: {{ block.settings.vertical_space_bt_items_mb }}px;
        padding-left: {{ block.settings.padding_left_mb }}px;
        padding-right: {{ block.settings.padding_right_mb }}px;
      }
    }

    {% if section.settings.hide_dots_on_mobile %}
      @media (max-width: 1149px) {
        #{{ section.id }} .hdt-slider__dots {
          display: none !important;
        }
      }
    {% endif %}
  {%- endstyle -%}
  <div id="{{ block.id }}" class="hdt-section-spacing hdt-s-gradient{% if block.settings.bg_image != blank %} hdt-has-bg-img{% endif %}{% if block.settings.half_item %} hdt-half_item{% endif %}{% if block.settings.hide_on_desktop %} hdt-hide-on-desktop{% endif %}{% if block.settings.hide_on_mobile %} hdt-hide-on-mobile{% endif %}{% if product_collection == blank %} hdt-hidden{% endif %}" style="--section-pt: {{ block.settings.padding_top }}px; --section-pb: {{ block.settings.padding_bottom }}px; --section-prate:{{ block.settings.padding_rate }};" color-scheme="{{ block.settings.color_scheme }}">
    {%- if block.settings.bg_image != blank -%}
      <div class="hdt-section-bg-img hdt-full-width-link">
        {%- assign image = block.settings.bg_image -%}
        {%- if image != blank -%}
          {{ image | image_url: width: image.width | image_tag: loading: 'lazy', width: image.width, height: image.height, sizes: '100vw', widths: '575,767,1024,1150,1366,1440,1920' }}
        {%- endif -%}
      </div>
    {%- endif -%}
    <div class="hdt-container{%- if block.settings.section_fullwidth -%}-full{% endif %} hdt-container-heading">
      {%- content_for 'block', type: '_collection_heading', id: 'featured-collection-carousel' -%}
    </div>
    <div class="hdt-container{%- if block.settings.section_fullwidth and block.settings.half_item == false -%}-full{% endif %}">
      <hdt-slider id="Slider-{{ block.id }}" class="hdt-collection-products hdt-slider__products hdt-slide-spacing-x hdt-collection-has-pr{{ block.settings.product_des }} hdt-pr-border_{{ block.settings.pr_border }} hdt-ratio--{{ block.settings.image_ratio }} {% unless block.settings.image_size %} hdt-ratio--contain{% endunless %} hdt-slider hdt-slider-parent hdt-slide-spacing-{{ block.settings.space_items }} hdt-relative {% if block.settings.navUI %}hdt-slider-has-nav hdt-nav-btns-{{ block.settings.nav_des }} hdt-nav-shape_{{ block.settings.nav_shape }} hdt-nav-{{ block.settings.nav_pos }} hdt-nav-{{ block.settings.nav_size }} hdt-slider-btn-vi-{{ block.settings.btn_vi }}{% endif %} {% if block.settings.dotUI %}hdt-slider-has-dots-dk{% endif %} hdt-dots-{{ block.settings.dots_des }} hdt-dots-rounded-{{ block.settings.dots_rounded }} lg:hdt-slides-{{ block.settings.col_dk | default: "auto" }} md:hdt-slides-{{ block.settings.col_tb | default: "auto" }} hdt-slides-{{ block.settings.col_mb | default: block.settings.col_mb | default: "auto" }}" config='{ "id": "Slider-{{ block.id }}", "navUI": {{ navUI }}, "dotUI": true, "navUICenter": true }' >
        <div class="hdt-slider__viewport hdt-relative">
          <div class="hdt-slider__container">
            {%- liquid 
              if product_collection != blank
                case block.settings.product_des
                  when '1'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0'
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                      endif
                    endcapture
                    for product in product_collection limit: block.settings.products_count
                      unless settings.remove_collection_url or block.settings.product_list != blank
                        assign product_url = product.url | within: block.settings.collection
                      endunless
                      render 'card-product1', card_product: product, class: "hdt-slider__slide hdt-pr-style1", section_id: block.id, sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                    endfor
                  when '2'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0'
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'right'
                      endif
                    endcapture
                    for product in product_collection limit: block.settings.products_count
                      unless settings.remove_collection_url or block.settings.product_list != blank
                        assign product_url = product.url | within: block.settings.collection
                      endunless
                      render 'card-product2', card_product: product, section_id: block.id, class: "hdt-slider__slide hdt-pr-style2", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                    endfor
                  when '3'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0'
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'left'
                      endif
                    endcapture
                    for product in product_collection limit: block.settings.products_count
                      unless settings.remove_collection_url or block.settings.product_list != blank
                        assign product_url = product.url | within: block.settings.collection
                      endunless
                      render 'card-product3', card_product: product, section_id: block.id, class: "hdt-slider__slide hdt-pr-style3", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                    endfor
                  when '4'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0'
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'left'
                      endif
                    endcapture
                    for product in product_collection limit: block.settings.products_count
                      unless settings.remove_collection_url or block.settings.product_list != blank
                        assign product_url = product.url | within: block.settings.collection
                      endunless
                      render 'card-product4', card_product: product, section_id: block.id, class: "hdt-slider__slide hdt-pr-style4", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                    endfor
                  when '5'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0'
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                      endif
                    endcapture
                    for product in product_collection limit: block.settings.products_count
                      unless settings.remove_collection_url or block.settings.product_list != blank
                        assign product_url = product.url | within: block.settings.collection
                      endunless
                      render 'card-product5', card_product: product, section_id: block.id, class: "hdt-slider__slide hdt-pr-style5", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                    endfor
                  when '6'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0'
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                      endif
                    endcapture
                    for product in product_collection limit: block.settings.products_count
                      unless settings.remove_collection_url or block.settings.product_list != blank
                        assign product_url = product.url | within: block.settings.collection
                      endunless
                      render 'card-product6', card_product: product, section_id: block.id, class: "hdt-slider__slide hdt-pr-style6", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                    endfor
                  when '7'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0'
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                      endif
                    endcapture
                    for product in product_collection limit: block.settings.products_count
                      unless settings.remove_collection_url or block.settings.product_list != blank
                        assign product_url = product.url | within: block.settings.collection
                      endunless
                      render 'card-product7', card_product: product, section_id: block.id, class: "hdt-slider__slide hdt-pr-style7 hdt-relative", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                    endfor
                  when '8'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0'
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                      endif
                    endcapture
                    for product in product_collection limit: block.settings.products_count
                      unless settings.remove_collection_url or block.settings.product_list != blank
                        assign product_url = product.url | within: block.settings.collection
                      endunless
                      render 'card-product8', card_product: product, section_id: block.id, class: "hdt-slider__slide hdt-pr-style8", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                    endfor
                  when '9'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0'
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                      endif
                    endcapture
                    for product in product_collection limit: block.settings.products_count
                      unless settings.remove_collection_url or block.settings.product_list != blank
                        assign product_url = product.url | within: block.settings.collection
                      endunless
                      render 'card-product9', card_product: product, section_id: block.id, class: "hdt-slider__slide hdt-pr-style1 hdt-pr-style9", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                    endfor
                  when '10'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0'
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                      endif
                    endcapture
                    for product in product_collection limit: block.settings.products_count
                      unless settings.remove_collection_url or block.settings.product_list != blank
                        assign product_url = product.url | within: block.settings.collection
                      endunless
                      render 'card-product10', card_product: product, section_id: block.id, class: "hdt-slider__slide hdt-pr-style1 hdt-pr-style10", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                    endfor
                    when '11' or '12'
                      capture btn_wishlist_code
                        if settings.wishlist_mode != '0'
                          render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                        endif
                      endcapture
                      for product in product_collection limit: block.settings.products_count
                        unless settings.remove_collection_url or block.settings.product_list != blank
                          assign product_url = product.url | within: block.settings.collection
                        endunless
                        assign class = "hdt-slider__slide hdt-pr-style1 hdt-pr-style" | append: block.settings.product_des
                        render 'card-product11', card_product: product, section_id: block.id, class: class, sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                      endfor
                  when '13'
                    for product in product_collection limit: block.settings.products_count
                      capture btn_wishlist_code
                        if settings.wishlist_mode != '0' and block.settings.show_wishlist
                          render 'wishlisthero-collection-product', product: product
                        endif
                      endcapture
                      unless settings.remove_collection_url or block.settings.product_list != blank
                        assign product_url = product.url | within: block.settings.collection
                      endunless
                      render 'card-product13', card_product: product, section_id: block.id, class: "hdt-slider__slide hdt-pr-style4", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, , show_vendor: block.settings.show_vendor, show_alt_image: block.settings.show_alt_image, show_secondary_image: block.settings.show_secondary_image, show_quick_view: block.settings.show_quick_view
                    endfor
                endcase
              else
                comment
                for i in (1..block.settings.products_count)
                  capture current
                  cycle 1, 2 , 3, 4
                  endcapture
                  assign placeholder_image = 'product-apparel-' | append: current
                  render 'card-product-placeholder', image_ratio: block.settings.image_ratio, placeholder_image: placeholder_image, section_id: block.id, class: "hdt-slider__slide"
                endfor
                endcomment
              endif
            -%}
          </div>
        </div>
        {% if block.settings.navUI %}
          {%- if block.settings.nav_pos != 'on_heading' -%}
            {%- render 'nav_slider', nav_id: block.id, nav_des: block.settings.nav_des, nav_icon: block.settings.nav_icon -%}
          {%- endif -%}
        {% endif %}
        {% if block.settings.dotUI %}
          <div hdt-slider-dots class="hdt-slider__dots hdt-flex hdt-align-center hdt-justify-{{ block.settings.dots_align }} no-js-hidden" aria-controls="Slider-{{ block.id }}" style="--dots-distance: {{ block.settings.dot_distance }}px;"></div>
      {% endif %}
      </hdt-slider>
      {% content_for 'blocks' %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "t:sections.collection_products.carousel_name",
  "tag": null,
  "class": "hdt-section hdt-featured-collection-grid",
  "blocks": [
    {
      "type": "_view-all"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.section_general_options"
    },
    {
      "id": "hide_on_desktop",
      "type": "checkbox",
      "label": "Hide on desktop",
      "default": false
    },
    {
      "id": "hide_on_mobile",
      "type": "checkbox",
      "label": "Hide on tablet, mobile",
      "default": false
    },
    {
      "id": "active_from",
      "label": "Active from (YYYY-MM-DD HH:MM:SS)",
      "type": "text",
      "placeholder": "Optional"
    },
    {
      "id": "active_to",
      "label": "Active up to (YYYY-MM-DD HH:MM:SS)",
      "type": "text",
      "placeholder": "Optional"
    },
    {
      "id": "collection",
      "type": "collection",
      "label": "t:sections.collection_products.settings.collection"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "t:sections.collection_products.settings.product_list.label",
      "info": "t:sections.collection_products.settings.product_list.info"
    },
    {
      "type": "select",
      "id": "product_des",
      "label": "t:sections.collection_products.settings.product_des",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4",
          "label": "4"
        },
        {
          "value": "5",
          "label": "5"
        },
        {
          "value": "6",
          "label": "6"
        },
        {
          "value": "7",
          "label": "7"
        },
        {
          "value": "8",
          "label": "8"
        },
        {
          "value": "9",
          "label": "9"
        },
        {
          "value": "10",
          "label": "10"
        },
        {
          "value": "11",
          "label": "11"
        },
        {
          "value": "12",
          "label": "12"
        },
        {
          "value": "13",
          "label": "13"
        }
      ],
      "default": "13"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt_image",
          "label": "t:sections.all.images.ratio.adapt_image.label"
        },
        {
          "value": "square",
          "label": "t:sections.all.images.ratio.square.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.all.images.ratio.portrait.label"
        },
        {
          "value": "asos",
          "label": "t:sections.all.images.ratio.asos.label"
        },
        {
          "value": "landscape",
          "label": "t:sections.all.images.ratio.landscape.label"
        },
        {
          "value": "custom-pr",
          "label": "t:sections.all.images.ratio.custom.label"
        }
      ],
      "label": "t:sections.all.images.ratio.label",
      "default": "adapt_image"
    },
    {
      "type": "checkbox",
      "id": "image_size",
      "label": "t:sections.all.images.size.cover",
      "default": true
    },
    {
        "type": "checkbox",
        "default": false,
        "id": "show_alt_image",
