<!-- blocks/image-text-column.liquid -->
{%- style -%}
  #{{ block.id }} .hdt-image-wrapper{
    grid-template-columns: repeat(12, 1fr);
    grid-template-rows: repeat(12, 1fr);
  }
  #{{ block.id }}::after{
    padding-bottom: {{ block.settings.height }}%;
    content:"";
    display: block;
  }
{%- endstyle -%}
<div id="{{ block.id }}" class="hdt-relative" {{ block.shopify_attributes }}>
  <div class="hdt-full-width-link hdt-grid hdt-image-wrapper">
      {% content_for 'blocks' %}
  </div>
</div>
{% schema %}
  {
    "name": "Column image",
    "tag": null,
    "blocks": [
      {
        "type": "_image-masonry"
      }
    ],
    "settings": [
      {
        "type": "range",
        "id": "height",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "%",
        "label": "Max height image",
        "default": 100
      }
    ],
    "presets": [
      {
        "name": "Column image"
      }
    ]
  }
{% endschema %}
