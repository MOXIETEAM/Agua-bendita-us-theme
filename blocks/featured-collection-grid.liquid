<!-- Featured-collection-grid.liquid -->
{%- comment -%}{{ 'hdt-card-products.css' | asset_url | stylesheet_tag }}{%- endcomment -%}
{% liquid
  if block.settings.active_from != blank
    assign from_dt = block.settings.active_from | date: "%s" | plus: 0
  else
    assign from_dt = 'now' | date: '%s' | minus: 1
  endif

  if block.settings.active_to != blank
    assign to_dt = block.settings.active_to | date: "%s" | plus: 0
  else
    assign to_dt = 'now' | date: '%s' | plus: 1
  endif

  assign now_dt = "now" | date: "%s" | plus: 0
%}

{% if from_dt <= now_dt and now_dt <= to_dt %}
  {%- assign collection = collections[block.settings.collection] -%}
  {%- paginate collection.products by block.settings.products_count -%}
  {%- liquid
    assign current_width = settings.page_width | append: 'px'
    assign current_width_tb = '100vw'
    assign current_width_mb = '100vw'
    assign space_item = "30px"
    assign space_item_tb = "15px"
    assign space_item_mb = "15px" 

    if block.settings.section_fullwidth
      if block.settings.boxed_fullwidth
        assign current_width = '100vw - 80px'
        assign current_width_tb = '100vw - 40px'
        assign current_width_mb = '100vw - 10px'
      else
        assign current_width = '100vw'
      endif
    endif
    assign product_collection = block.settings.product_list | default: collection.products
    assign products_id = 'products-' | append: block.id
    assign color_list = 'products.theme_settings.color' | t | downcase | strip | replace: ' ,', ',' | replace: ', ', ',' | split: ',' | uniq
    assign size_list = 'products.theme_settings.size' | t | downcase | strip | replace: ' ,', ',' | replace: ', ', ',' | split: ',' | uniq 

     assign col_mb = block.settings.col_mb | plus: 0
     assign col_tb = block.settings.col_tb | plus: 0
     assign col_dk = block.settings.col_dk | plus: 0
  -%}

  {%- capture sizes -%}
    (min-width: 1150px) calc(({{ current_width }} -  {{ space_item }} * {{ block.settings.col_dk | minus: 1 }}) * {{ 1.00 | divided_by: block.settings.col_dk | round: 2 }}) {{- -}}
    , (min-width: 768px) calc( ({{ current_width_tb }} - {{ space_item_tb }} * {{ block.settings.col_tb | minus: 1 }} ) * {{ 1.00 | divided_by: block.settings.col_tb | round: 2 }})  {{- -}}
    , calc( ({{ current_width_mb }} - {{ space_item_mb }} * {{ block.settings.col_mb | minus: 1 }} ) * {{ 1.00 | divided_by: block.settings.col_mb | round: 2 }})
  {%- endcapture -%}
  {%- render 'section-layout-design' -%}
  {%- style -%}{%- if block.settings.boxed_fullwidth -%}#{{block.id}} .hdt-container-full{padding-inline-start:15px;padding-inline-end:15px}@media(min-width:768px){#{{block.id}} .hdt-container-full{padding-inline-start:30px;padding-inline-end:30px}}@media(min-width:1150px){#{{block.id}} .hdt-container-full{padding-inline-start:30px;padding-inline-end:30px}}{%- endif -%}{%- if block.settings.products_count < col_mb -%}@media(max-width:767px){#{{block.id}} .hdt-pr-border_on_grid:not(.hdt-slider):not(.hdt-collection-has-pr6):not(.hdt-collection-has-pr7){border-inline-start:none;border-radius:0}#{{block.id}} .hdt-pr-border_on_grid:not(.hdt-slider):not(.hdt-collection-has-pr6):not(.hdt-collection-has-pr7) .hdt-card-product:first-child{border-inline-start:solid 1px rgb(var(--color-line-border))}.dir--ltr #{{block.id}} .hdt-pr-border_on_grid:not(.hdt-slider):not(.hdt-collection-has-pr6):not(.hdt-collection-has-pr7) .hdt-card-product:first-child,.dir--rtl #{{block.id}} .hdt-pr-border_on_grid:not(.hdt-slider):not(.hdt-collection-has-pr6):not(.hdt-collection-has-pr7) .hdt-card-product:last-child{border-top-left-radius:var(--rounded-product-card);border-bottom-left-radius:var(--rounded-product-card)}.dir--ltr #{{block.id}} .hdt-pr-border_on_grid:not(.hdt-slider):not(.hdt-collection-has-pr6):not(.hdt-collection-has-pr7) .hdt-card-product:last-child,.dir--rtl #{{block.id}} .hdt-pr-border_on_grid:not(.hdt-slider):not(.hdt-collection-has-pr6):not(.hdt-collection-has-pr7) .hdt-card-product:first-child{border-top-right-radius:var(--rounded-product-card);border-bottom-right-radius:var(--rounded-product-card)}}{%- endif -%}{%- if block.settings.products_count < col_tb -%}@media(min-width:768px) and (max-width:1149px){#{{block.id}} .hdt-pr-border_on_grid:not(.hdt-slider):not(.hdt-collection-has-pr6):not(.hdt-collection-has-pr7){border-inline-start:none;border-radius:0}#{{block.id}} .hdt-pr-border_on_grid:not(.hdt-slider):not(.hdt-collection-has-pr6):not(.hdt-collection-has-pr7) .hdt-card-product:first-child{border-inline-start:solid 1px rgb(var(--color-line-border))}.dir--ltr #{{block.id}} .hdt-pr-border_on_grid:not(.hdt-slider):not(.hdt-collection-has-pr6):not(.hdt-collection-has-pr7) .hdt-card-product:first-child,.dir--rtl #{{block.id}} .hdt-pr-border_on_grid:not(.hdt-slider):not(.hdt-collection-has-pr6):not(.hdt-collection-has-pr7) .hdt-card-product:last-child{border-top-left-radius:var(--rounded-product-card);border-bottom-left-radius:var(--rounded-product-card)}.dir--ltr #{{block.id}} .hdt-pr-border_on_grid:not(.hdt-slider):not(.hdt-collection-has-pr6):not(.hdt-collection-has-pr7) .hdt-card-product:last-child,.dir--rtl #{{block.id}} .hdt-pr-border_on_grid:not(.hdt-slider):not(.hdt-collection-has-pr6):not(.hdt-collection-has-pr7) .hdt-card-product:first-child{border-top-right-radius:var(--rounded-product-card);border-bottom-right-radius:var(--rounded-product-card)}}{%- endif -%}{%- if block.settings.products_count < col_dk -%}@media(min-width:1150px){#{{block.id}} .hdt-pr-border_on_grid:not(.hdt-slider):not(.hdt-collection-has-pr6):not(.hdt-collection-has-pr7){border-inline-start:none;border-radius:0}#{{block.id}} .hdt-pr-border_on_grid:not(.hdt-slider):not(.hdt-collection-has-pr6):not(.hdt-collection-has-pr7) .hdt-card-product:first-child{border-inline-start:solid 1px rgb(var(--color-line-border))}.dir--ltr #{{block.id}} .hdt-pr-border_on_grid:not(.hdt-slider):not(.hdt-collection-has-pr6):not(.hdt-collection-has-pr7) .hdt-card-product:first-child,.dir--rtl #{{block.id}} .hdt-pr-border_on_grid:not(.hdt-slider):not(.hdt-collection-has-pr6):not(.hdt-collection-has-pr7) .hdt-card-product:last-child{border-top-left-radius:var(--rounded-product-card);border-bottom-left-radius:var(--rounded-product-card)}.dir--ltr #{{block.id}} .hdt-pr-border_on_grid:not(.hdt-slider):not(.hdt-collection-has-pr6):not(.hdt-collection-has-pr7) .hdt-card-product:last-child,.dir--rtl #{{block.id}} .hdt-pr-border_on_grid:not(.hdt-slider):not(.hdt-collection-has-pr6):not(.hdt-collection-has-pr7) .hdt-card-product:first-child{border-top-right-radius:var(--rounded-product-card);border-bottom-right-radius:var(--rounded-product-card)}}{%- endif -%}

    @media(min-width: 1150px) {
      #{{ block.id }} {
        --spacing-x: {{ block.settings.horizontal_space_bt_items }}px;
        --spacing-y: {{ block.settings.vertical_space_bt_items }}px;
        padding-left: {{ block.settings.padding_left }}px;
        padding-right: {{ block.settings.padding_right }}px;
      }
    }
    @media(max-width: 1149px) {
      #{{ block.id }} {
        --spacing-x: {{ block.settings.horizontal_space_bt_items_mb }}px;
        --spacing-y: {{ block.settings.vertical_space_bt_items_mb }}px;
        padding-left: {{ block.settings.padding_left_mb }}px;
        padding-right: {{ block.settings.padding_right_mb }}px;
      }
    }
  {%- endstyle -%}

  {% liquid
    capture hide_class
      render "hide_desktop_mobile", hide_on_desktop: block.settings.hide_on_desktop, hide_on_mobile: block.settings.hide_on_mobile
    endcapture
  %}
  <div id="{{ block.id }}" class="hdt-section-spacing hdt-s-gradient {{ hide_class }}" color-scheme="{{ block.settings.color_scheme }}" style="--section-pt: {{ block.settings.padding_top }}px; --section-pb: {{ block.settings.padding_bottom }}px; --section-prate:{{ block.settings.padding_rate }};" color-scheme="{{ block.settings.color_scheme }}">
    <div class="hdt-container{%- if block.settings.section_fullwidth -%}-full{% endif %}">
      {%- content_for 'block', type: 'section-heading', id: 'collection-grid' -%}
      <hdt-reval-items reveal-on-scroll="true" id="{{ products_id }}" scroll-into-view class="hdt-collection-products hdt-collection-has-pr{{ block.settings.product_des }} hdt-pr-border_{{ block.settings.pr_border }} hdt-row-grid hdt-row-grid--modify hdt-justify-{{ block.settings.align_content }} hdt-ratio--{{ block.settings.image_ratio }} {% unless block.settings.image_size %} hdt-ratio--contain{% endunless %} lg:hdt-grid-cols-{{ block.settings.col_dk }} md:hdt-grid-cols-{{ block.settings.col_tb }} hdt-grid-cols-{{ block.settings.col_mb }}" >
        {%- liquid 
          if product_collection != blank
            case block.settings.product_des
              when '1'
                capture btn_wishlist_code
                  if settings.wishlist_mode != '0' and block.settings.show_wishlist
                    render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                  endif
                endcapture
                for product in product_collection limit: block.settings.products_count
                  unless settings.remove_collection_url or block.settings.product_list != blank
                    assign product_url = product.url | within: block.settings.collection
                  endunless
                  render 'card-product1', card_product: product, class: "hdt-pr-style1", section_id: block.id, sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor, show_alt_image: block.settings.show_alt_image, show_quick_view: block.settings.show_quick_view
                endfor
              when '2'
                capture btn_wishlist_code
                  if settings.wishlist_mode != '0' and block.settings.show_wishlist
                    render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'right'
                  endif
                endcapture
                for product in product_collection limit: block.settings.products_count
                  unless settings.remove_collection_url or block.settings.product_list != blank
                    assign product_url = product.url | within: block.settings.collection
                  endunless
                  render 'card-product2', card_product: product, section_id: block.id, class: "hdt-pr-style2", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor, show_alt_image: block.settings.show_alt_image, show_quick_view: block.settings.show_quick_view
                endfor
              when '3'
                capture btn_wishlist_code
                  if settings.wishlist_mode != '0'
                    render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'left'
                  endif
                endcapture
                for product in product_collection limit: block.settings.products_count
                  unless settings.remove_collection_url or block.settings.product_list != blank
                    assign product_url = product.url | within: block.settings.collection
                  endunless
                  render 'card-product3', card_product: product, section_id: block.id, class: "hdt-pr-style3", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                endfor
              when '4'
                capture btn_wishlist_code
                  if settings.wishlist_mode != '0'
                    render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'left'
                  endif
                endcapture
                for product in product_collection limit: block.settings.products_count
                  unless settings.remove_collection_url or block.settings.product_list != blank
                    assign product_url = product.url | within: block.settings.collection
                  endunless
                  render 'card-product4', card_product: product, section_id: block.id, class: "hdt-pr-style4", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                endfor
              when '5'
                capture btn_wishlist_code
                  if settings.wishlist_mode != '0'
                    render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                  endif
                endcapture
                for product in product_collection limit: block.settings.products_count
                  unless settings.remove_collection_url or block.settings.product_list != blank
                    assign product_url = product.url | within: block.settings.collection
                  endunless
                  render 'card-product5', card_product: product, section_id: block.id, class: "hdt-pr-style5", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                endfor
              when '6'
                capture btn_wishlist_code
                  if settings.wishlist_mode != '0'
                    render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                  endif
                endcapture
                for product in product_collection limit: block.settings.products_count
                  unless settings.remove_collection_url or block.settings.product_list != blank
                    assign product_url = product.url | within: block.settings.collection
                  endunless
                  render 'card-product6', card_product: product, section_id: block.id, class: "hdt-pr-style6", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                endfor
              when '7'
                capture btn_wishlist_code
                  if settings.wishlist_mode != '0'
                    render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                  endif
                endcapture
                for product in product_collection limit: block.settings.products_count
                  unless settings.remove_collection_url or block.settings.product_list != blank
                    assign product_url = product.url | within: block.settings.collection
                  endunless
                  render 'card-product7', card_product: product, section_id: block.id, class: "hdt-pr-style7 hdt-relative", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                endfor
              when '8'
                capture btn_wishlist_code
                  if settings.wishlist_mode != '0'
                    render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                  endif
                endcapture
                for product in product_collection limit: block.settings.products_count
                  unless settings.remove_collection_url or block.settings.product_list != blank
                    assign product_url = product.url | within: block.settings.collection
                  endunless
                  render 'card-product8', card_product: product, section_id: block.id, class: "hdt-pr-style8", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                endfor
              when '9'
                capture btn_wishlist_code
                  if settings.wishlist_mode != '0'
                    render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                  endif
                endcapture
                for product in product_collection limit: block.settings.products_count
                  unless settings.remove_collection_url or block.settings.product_list != blank
                    assign product_url = product.url | within: block.settings.collection
                  endunless
                  render 'card-product9', card_product: product, section_id: block.id, class: "hdt-pr-style1 hdt-pr-style9", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                endfor
              when '10'
                capture btn_wishlist_code
                  if settings.wishlist_mode != '0'
                    render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                  endif
                endcapture
                for product in product_collection limit: block.settings.products_count
                  unless settings.remove_collection_url or block.settings.product_list != blank
                    assign product_url = product.url | within: block.settings.collection
                  endunless
                  render 'card-product10', card_product: product, section_id: block.id, class: "hdt-pr-style1 hdt-pr-style10", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                endfor
              when '11' or '12'
                capture btn_wishlist_code
                  if settings.wishlist_mode != '0'
                    render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                  endif
                endcapture
                for product in product_collection limit: block.settings.products_count
                  unless settings.remove_collection_url or block.settings.product_list != blank
                    assign product_url = product.url | within: block.settings.collection
                  endunless
                  assign class = "hdt-slider__slide hdt-pr-style1 hdt-pr-style" | append: block.settings.product_des
                  render 'card-product11', card_product: product, section_id: block.id, class: class, sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor
                endfor
              when '13'
                for product in product_collection limit: block.settings.products_count
                  capture btn_wishlist_code
                    if settings.wishlist_mode != '0' and block.settings.show_wishlist
                      render 'wishlisthero-collection-product', product: product
                    endif
                  endcapture
                  unless settings.remove_collection_url or block.settings.product_list != blank
                    assign product_url = product.url | within: block.settings.collection
                  endunless
                  render 'card-product13', card_product: product, section_id: block.id, class: "hdt-pr-style4", sizes: sizes, image_ratio: block.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: block.settings.show_vendor, show_alt_image: block.settings.show_alt_image, show_secondary_image: block.settings.show_secondary_image, show_quick_view: block.settings.show_quick_view
                endfor
            endcase
          else
            comment
            for i in (1..block.settings.products_count)
              capture current
              cycle 1, 2 , 3, 4
              endcapture
              assign placeholder_image = 'product-apparel-' | append: current
              render 'card-product-placeholder', image_ratio: block.settings.image_ratio, placeholder_image: placeholder_image, section_id: block.id
            endfor
            endcomment
          endif
        -%}
      </hdt-reval-items>
      {% content_for 'blocks' %}
    </div>
  </div>
  {%- endpaginate -%}
{% endif %}

{% schema %}
{
  "name": "t:sections.collection_products.grid_name",
  "tag": null,
  "class": "hdt-section hdt-featured-collection-grid",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.section_general_options"
    },
    {
      "id": "hide_on_desktop",
      "type": "checkbox",
      "label": "Hide on desktop",
      "default": false
    },
    {
      "id": "hide_on_mobile",
      "type": "checkbox",
      "label": "Hide on tablet, mobile",
      "default": false
    },
    {
      "id": "active_from",
      "label": "Active from (YYYY-MM-DD HH:MM:SS)",
      "type": "text",
      "placeholder": "Optional"
    },
    {
      "id": "active_to",
      "label": "Active up to (YYYY-MM-DD HH:MM:SS)",
      "type": "text",
      "placeholder": "Optional"
    },
    {
      "id": "collection",
      "type": "collection",
      "label": "t:sections.collection_products.settings.collection"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "t:sections.collection_products.settings.product_list.label",
      "info": "t:sections.collection_products.settings.product_list.info"
    },
    {
      "type": "select",
      "id": "product_des",
      "label": "t:sections.collection_products.settings.product_des",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4",
          "label": "4"
        },
        {
          "value": "5",
          "label": "5"
        },
        {
          "value": "6",
          "label": "6"
        },
        {
          "value": "7",
          "label": "7"
        },
        {
          "value": "8",
          "label": "8"
        },
        {
          "value": "9",
          "label": "9"
        },
        {
          "value": "10",
          "label": "10"
        },
        {
          "value": "11",
          "label": "11"
        },
        {
          "value": "12",
          "label": "12"
        },
        {
          "value": "13",
          "label": "13"
        },
      ],
      "default": "13"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt_image",
          "label": "t:sections.all.images.ratio.adapt_image.label"
        },
        {
          "value": "square",
          "label": "t:sections.all.images.ratio.square.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.all.images.ratio.portrait.label"
        },
        {
          "value": "asos",
          "label": "t:sections.all.images.ratio.asos.label"
        },
        {
          "value": "landscape",
          "label": "t:sections.all.images.ratio.landscape.label"
        },
        {
          "value": "custom-pr",
          "label": "t:sections.all.images.ratio.custom.label"
        }
      ],
      "label": "t:sections.all.images.ratio.label",
      "default": "adapt_image"
    },
    {
      "type": "checkbox",
      "id": "image_size",
      "label": "t:sections.all.images.size.cover",
      "default": true
    },
    {
        "type": "checkbox",
        "default": false,
        "id": "show_alt_image",
        "label": "Use product alternative image?"
    },
    {
        "type": "checkbox",
        "default": false,
        "id": "show_secondary_image",
        "label": "Show secondary image on hover?"
    },
    {
      "type": "checkbox",
      "id": "show_quick_view",
      "label": "t:settings_schema.product_card.settings.product_buttons.show_quick_view.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "Show wishlist",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:sections.collection_products.settings.show_vendor",
      "default": false
    },
    {
      "type": "select",
      "id": "pr_border",
      "options": [
        {
          "value": "none",
          "label": "t:sections.collection_products.settings.pr_border.none"
        },
