{% liquid
  unless product
    assign product = section.settings.product
  endunless
%}
{% liquid
  capture hide_class
    render "hide_desktop_mobile", hide_on_desktop: block.settings.hide_on_desktop, hide_on_mobile: block.settings.hide_on_mobile
  endcapture
%}
<a class="hdt-product-info__item hdt-product__btn-details hdt-inline-flex hdt-justify-center hdt-align-center hdt-text-base hdt-font-semibold {{ hide_class }}" href="{{ product.url }}">
  {{ 'products.product.view_products_details' | t }}
  <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 8 8" fill="none"><path d="M0.861539 8L0 7.13846L5.90769 1.23077H0.615385V0H8V7.38462H6.76923V2.09231L0.861539 8Z" fill="currentColor"/></svg>
</a>

{% schema %}
  {
    "name": "View product detail",
    "tag": null,
    "settings": [
      {
        "id": "hide_on_desktop",
        "type": "checkbox",
        "label": "Hide on desktop",
        "default": false
      },
      {
        "id": "hide_on_mobile",
        "type": "checkbox",
        "label": "Hide on tablet, mobile",
        "default": false
      },
    ],
    "presets": [
      {
        "name": "View product detail",
      }
    ]
  }
{% endschema %}
