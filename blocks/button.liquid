{% liquid
  assign effect = 'hdt-reveal="slide-in" timeline'
  if section.id contains 'slideshow'
    assign effect = 'reval'
  endif   

  assign is_link = false
  if block.settings.behavior == "open_link"
    assign is_link = true
  endif

  assign tag = "a"
  unless is_link
    assign tag = "button"
  endunless

  assign has_icon = false
  if block.setings.icon != "none" or block.settings.custom_icon != "none"
    assign has_icon = true
  endif
%}
<{{ tag }} {{ effect }} id="block-{{ block.id }}" {% if block.settings.link == blank and is_link %}role="link" aria-disabled="true"{% elsif is_link %}href="{{ block.settings.link }}"{% endif %} class="hdt-button-block hdt-btn hdt-relative hdt-font-{{ block.settings.font_weight }} hdt-btn--size-{{ block.settings.font_size }} hdt-btn-{{ block.settings.style_class }}{% if block.settings.full_width %} hdt-btn-full-width{% endif %}{% if has_icon %} hdt-btn--with-icon  hdt-btn--pos-icon-{{ block.settings.icon_position }}{% endif %}"{% if has_icon %} style="--gap-btn-icon: {{ block.settings.icon_spacing }}px; --height-btn-icon: {{ block.settings.icon_height }}px"{% endif %} {% if block.settings.open_in_new_tab %} target="_blank" rel="noopener noreferrer"{% endif -%} {{ block.shopify_attributes }}>

  {%- liquid
  if block.settings.icon != 'none'
    render 'icons', icon: block.settings.icon
  endif
  if block.settings.custom_icon != 'none'
    render 'custom-icons', icon: block.settings.custom_icon
  endif
  echo block.settings.label
  -%}
</{{ tag }}>
{%- style -%}
  #block-{{ block.id }} {
    text-transform: {{ block.settings.text_transform }};
    --min-width-btn: {{ block.settings.min_width_btn }}px;
    --min-width-btn-dt: {{ block.settings.min_width_dt_btn }}px;

    &::after {
      content: unset;
    }

    {%- if block.settings.font_size == "custom custom-inline" -%}
      --padding-button: {{ block.settings.vertical_padding_btn }}px {{ block.settings.horizontal_padding_btn }}px; --height-button: {{ block.settings.min_height_btn }}px; --font-size-button: {{ block.settings.font_size_btn }}px;


        {% if block.settings.letter_spacing_text %}
          letter-spacing: {{ block.settings.letter_spacing_text }}px;
        {% endif %}


      @media(max-width: 1149px) {
        --font-size-button: {{ block.settings.font_size_btn_mb }}px;
      }
    {%- endif -%}

    text-decoration: none !important;
    color: #000000 !important;
    border-width: {{ block.settings.border_width }}px;

    &.hdt-btn-outline:hover {
      background-color: transparent !important;
    }
    &.hdt-btn-solid {
      color: {{ block.settings.solid_label_color }} !important;
      border-color: {{ block.settings.solid_border_color }} !important;
    }
    &.hdt-btn-outline {
      color: {{ block.settings.outline_color }} !important;
      border-color: {{ block.settings.outline_color }} !important;
    }
    --color-button: 0 0 0;
    {%- if block.settings.specific_bg_color != blank -%}
      &.hdt-btn-solid {
        background-color: {{ block.settings.specific_bg_color }} !important;
      }
    {%- endif -%}
  }
{%- endstyle -%}
