{{ 'hdt-product-tabs.css' | asset_url | stylesheet_tag }}
{%- style -%}
  #block-{{ block.id }} {
    --section-pt:{{ block.settings.padding_top }}px; --section-pb:{{ block.settings.padding_bottom }}px; --section-prate:{{ block.settings.padding_rate }};
  }
{%- endstyle -%}

{%- capture tab_list -%}
  {% content_for "blocks" %}
{%- endcapture -%}
{%- assign tab_list_title = tab_list | split: '<!--item-title>' -%}

<div id="block-{{ block.id }}" class="hdt-product-info__item hdt-product__tabs" data-type={{ block.type }} {{ block.shopify_attributes }}>
  <div class="hdt-product-tab hdt-s-gradient hdt-section-spacing" color-scheme="{{ block.settings.color_scheme }}">
    <div class="hdt-container{% if block.settings.full_width %}-full{% endif %}">
      {%- if block.settings.tabs_design == 'tab' or block.settings.tabs_design == 'tab_vertical' -%}
        <div class="hdt-type-tab">
          <div class="hdt-product-tab__wrap hdt-product-tab--{% if block.settings.tabs_design == 'tab' %}default{% else %}vertical{% endif %}">
            <hdt-tab class="hdt-product-tab__main hdt-flex hdt-scroll-snap hdt-snap-x" aria-controls="product-tabs-{{ block.settings.tabs_design }}-{{ block.id }}">
              {%- for tab in tab_list_title -%}
                {{- tab | split: '-->' | first -}}
              {%- endfor -%}
            </hdt-tab>
            <div class="hdt-product-tab__content" id="product-tabs-{{ block.settings.tabs_design }}-{{ block.id }}">
              {{ tab_list }}
            </div>
          </div>
        </div>
      {%- elsif block.settings.tabs_design == 'accordion' -%}
        <div class="hdt-type-accordion">
          {%- assign accordion_index = 0 -%}
          {%- for tab in tab_list_title -%}
            {%- assign tab_content = tab | split: '-->' | last -%}
            {%- if tab_content != blank -%}
              <hdt-accordion class="hdt-contents">
                <details class="hdt-product-accordion__item" {% if accordion_index == 0 and block.settings.enable_first_tab %}open {% endif %}>
                  <summary aria-expanded="{% if accordion_index == 0 and block.settings.enable_first_tab %}true{% else %}false{% endif %}">
                    {%- assign tab_title_html = tab | split: '-->' | first -%}
                    {%- assign tab_title = tab_title_html | strip_html -%}
                    <span class="hdt-product-accordion__text hdt-s-text hdt-font-semibold">{{ tab_title }}</span>
                    <span class="hdt-product-accordion__icon"></span>
                  </summary>
                  <div class="hdt-product-accordion__content hdt-rte">{{ tab_content }}</div>
                </details>
              </hdt-accordion>
              {%- assign accordion_index = accordion_index | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="hdt-type-list">
          {%- for tab in tab_list_title -%}
            {%- assign tab_content = tab | split: '-->' | last -%}
            {%- if tab_content != blank -%}
              <div class="hdt-product-tab__item">
                {%- assign tab_title_html = tab | split: '-->' | first -%}
                {%- assign tab_title = tab_title_html | strip_html -%}
                <div class="hdt-product-tab__item-title hdt-s-text hdt-font-semibold">{{ tab_title }}</div>
                <div class="hdt-product-tab__item-content hdt-rte">{{ tab_content }}</div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Information Tabs",
  "tag": null,
  "class": "hdt-section hdt-section-main-product-tabs",
  "blocks": [
    {
      "type": "_information-tab-des"
    },
    {
      "type": "_information-tab-add"
    },
    {
      "type": "_information-tab-review"
    },
    {
      "type": "_information-tab-html"
    },
    {
      "type": "_information-tab-liquid"
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "tabs_design",
      "label": "t:sections.main-product-tabs.settings.tabs_design.label",
      "default": "tab",
      "options": [
        {
          "value": "tab",
          "label": "t:sections.main-product-tabs.settings.tabs_design.options__1.label"
        },
        {
          "value": "tab_vertical",
          "label": "t:sections.main-product-tabs.settings.tabs_design.options__2.label"
        },
        {
          "value": "accordion",
          "label": "t:sections.main-product-tabs.settings.tabs_design.options__3.label"
        },
        {
          "value": "list",
          "label": "t:sections.main-product-tabs.settings.tabs_design.options__4.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_first_tab",
      "label": "t:sections.main-product-tabs.settings.enable_first_tab.label",
      "info": "t:sections.main-product-tabs.settings.enable_first_tab.info",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "t:sections.all.full_width.label",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_rate",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:sections.all.padding.padding_rate",
      "default": 75
    }
  ],
  "presets": [
    {
      "name": "Information Tabs"
    }
  ]
}
{% endschema %}
