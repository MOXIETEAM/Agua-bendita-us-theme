<!--image-gallery block -->
{% liquid
  if block.settings.active_from != blank
    assign from_dt = block.settings.active_from | date: "%s" | plus: 0
  else
    assign from_dt = 'now' | date: '%s' | minus: 1
  endif

  if block.settings.active_to != blank
    assign to_dt = block.settings.active_to | date: "%s" | plus: 0
  else
    assign to_dt = 'now' | date: '%s' | plus: 1
  endif

  assign now_dt = "now" | date: "%s" | plus: 0
%}

{% if from_dt <= now_dt and now_dt <= to_dt %}
  {%- liquid
    assign current_width = settings.page_width | append: 'px'
    assign current_width_tb = '100vw'
    assign current_width_mb = '100vw'
    assign space_item = block.settings.spacing_items
    
    if block.settings.section_fullwidth
      if block.settings.boxed_fullwidth
        assign current_width = '100vw - 80px'
        assign current_width_tb = '100vw - 40px'
        assign current_width_mb = '100vw - 10px'
      else
        assign current_width = '100vw'
      endif
    endif
    assign image_action = block.settings.image_action
    assign action_element = 'hdt-gallery-modal'
    if image_action == 'go_link'
      assign action_element = 'div'
    endif
    
    -%}
    
    {%- capture sizes -%}
      (min-width: 1150px) calc(({{ current_width }} -  ({{ space_item }} * ( {{ block.settings.col_dk }} - 1 ))) * 1 / {{ block.settings.col_dk }}),(min-width: 768px) calc( ({{ current_width_tb }} - ({{ space_item }} * ( {{ block.settings.col_tb }} - 1 ))) * 1 / {{ block.settings.col_tb }}), calc( ({{ current_width_mb }} - ({{ space_item }} * ( {{ block.settings.col_mb }} - 1 ) )) * 1 / {{ block.settings.col_mb }})
    {%- endcapture -%}
    {%- style -%} #block-{{ block.id }} .hdt-slider{--slide-spacing:{{block.settings.spacing_items}}px}.hdt-image-gallery :is(wrapp-hdt-open-modal-btn, hdt-tooltip) { display:block;width:33px;height:33px;border-radius:var(--rounded-full);right:5px;top:5px;bottom:5px;left:5px;margin:auto;z-index:3; position: absolute;overflow: hidden; }.hdt-gallery-product{width:100%;height:100%;color:rgba(var(--color-button-text));background-color:rgba(var(--color-button));transition:.4s ease .1s}.hdt-gallery-product svg{width:12px;height:12px}.hdt-gallery-item .hdt-gallery-img::before{position:absolute;z-index:2;content:"";width:100%;height:100%;background-color:rgba(0,0,0,.1);top:0;left:0;transition:.4s ease .1s;opacity:0;visibility:hidden}.hdt-gallery-item .hdt-gallery-img img{transition:transform 2s cubic-bezier(0,0,.44,1.18);object-position:{{ block.settings.image_position }}}.hdt-section-head.hdt-text-center,.hdt-section-head.hdt-justify-center{padding-inline-start:15px;padding-inline-end:15px}{% if block.settings.spacing_items==0 %}.hdt-gallery-item .hdt-gallery-inner{border-radius:0}#block-{{ block.id }} >:not(.hdt-container-full) .hdt-slider__viewport{border-radius:var(--rounded)}{% endif %}@media (-moz-touch-enabled:0),(hover:hover) and (min-width:1150px){.hdt-gallery-product:hover{background-color:rgba(var(--color-button-text));color:rgba(var(--color-button))}.hdt-gallery-item:hover .hdt-gallery-img img{transform:scale(1.09)}.hdt-gallery-product{opacity:0;visibility:hidden;transition:0.4s ease 0.1s}.hdt-gallery-item:hover .hdt-gallery-img::before,.hdt-gallery-item:hover .hdt-gallery-product{opacity:1;visibility:visible}}{% if block.settings.boxed_fullwidth %}#block-{{block.id}} .hdt-container-full{padding-inline-start:15px;padding-inline-end:15px}@media(min-width:768px){#block-{{block.id}} .hdt-container-full{padding-inline-start:30px;padding-inline-end:30px}}@media(min-width:1150px){#block-{{block.id}} .hdt-container-full{padding-inline-start:40px;padding-inline-end:40px}}{% endif %}{% if block.settings.mobile_layout == 'grid' %}@media(max-width:1149px){#block-{{ block.id }} .hdt-slider{display:block}#block-{{ block.id }} .hdt-slider__viewport{overflow:visible}#block-{{ block.id }} .hdt-slider__container{display:grid;grid-template-columns:repeat({{ block.settings.col_mb }},1fr);gap:{{ block.settings.spacing_items }}px;transform:none!important}#block-{{ block.id }} .hdt-slider__slide{min-width:0;flex:none}#block-{{ block.id }} .hdt-slider__dots,#block-{{ block.id }} .hdt-slider-nav{display:none!important}}{% endif %}{% if block.settings.desktop_layout == 'grid' %}@media(min-width:1150px){#block-{{ block.id }} .hdt-slider{display:block}#block-{{ block.id }} .hdt-slider__viewport{overflow:visible}#block-{{ block.id }} .hdt-slider__container{display:grid;grid-template-columns:repeat({{ block.settings.col_dk }},1fr);gap:{{ block.settings.spacing_items }}px;transform:none!important}#block-{{ block.id }} .hdt-slider__slide{min-width:0;flex:none}#block-{{ block.id }} .hdt-slider__dots,#block-{{ block.id }} .hdt-slider-nav{display:none!important}}{% endif %}{%- endstyle -%}
    {%- liquid
      capture hide_class
        render 'hide_desktop_mobile', hide_on_desktop: block.settings.hide_on_desktop, hide_on_mobile: block.settings.hide_on_mobile
      endcapture
    -%}
    <div id="block-{{ block.id }}" class="hdt-section hdt-image-gallery hdt-section-spacing hdt-s-gradient {{ hide_class }}" style="--section-pt: {{ block.settings.padding_top }}px; --section-pb: {{ block.settings.padding_bottom }}px; --section-prate:{{ block.settings.padding_rate }};" color-scheme="{{ block.settings.color_scheme }}" {{ block.shopify_attributes }}>
      <{{ action_element }} class="hdt-container{%- if block.settings.section_fullwidth -%}-full{%- endif -%}">
        {%- render 'section-top-head', sec_heading: block.settings.sec_heading, sec_subheading: block.settings.sec_subheading, heading_tag: block.settings.heading_tag, heading_size: block.settings.heading_size, subheading_size: block.settings.subheading_size, heading_align: block.settings.heading_align, heading_reverse: block.settings.heading_reverse, heading_gap: block.settings.heading_gap, sec_heading_spacing: block.settings.sec_heading_spacing -%}
        <hdt-slider id="Slider-{{ block.id }}" class="hdt-slider hdt-slider-parent hdt-relative hdt-hidden-slider-nav {% if block.settings.navUI %}hdt-slider-has-nav hdt-nav-btns-{{ block.settings.nav_des }} hdt-nav-shape_{{ block.settings.nav_shape }} hdt-nav-{{ block.settings.nav_pos }} hdt-nav-{{ block.settings.nav_size }} hdt-slider-btn-vi-{{ block.settings.btn_vi }}{% endif %} {% if block.settings.dotUI %} hdt-slider-has-dots-dk{% endif %} hdt-slider__dots_{{ block.settings.dots_pos }} hdt-dots-outline hdt-oh hdt-ratio--{{ block.settings.image_ratio }} {% unless block.settings.image_size %} hdt-ratio--contain{% endunless %} lg:hdt-slides-{{ block.settings.col_dk }} md:hdt-slides-{{ block.settings.col_tb }} hdt-slides-{{ block.settings.col_mb }}" config='{ "id": "Slider-{{ block.id }}", "navUI": {{ block.settings.navUI }}, "dotUI": true, "navUICenter": true }'>
          <div class="hdt-slider__viewport hdt-relative">
            <div class="hdt-slider__container">
              {%- liquid
                assign closest_sizes = sizes
                assign closest_image_action = image_action
              -%}
              {% content_for "blocks" %}
            </div>
            {%- if block.settings.navUI -%}
              {%- render 'nav_slider', nav_des: block.settings.nav_des, nav_icon: block.settings.nav_icon -%}
            {%- endif -%}
            <div hdt-slider-dots class="hdt-slider__dots hdt-flex hdt-align-center hdt-justify-center" aria-controls="Slider-{{ block.id }}"></div>
          </div>
        </hdt-slider>
      </{{ action_element }}>
    </div>
{% endif %}
{% schema %}
