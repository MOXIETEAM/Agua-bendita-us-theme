{% liquid
  capture hide_class
    render "hide_desktop_mobile", hide_on_desktop: block.settings.hide_on_desktop, hide_on_mobile: block.settings.hide_on_mobile, display_type: "grid"
  endcapture
%}
<div id="{{ block.id }}" class="hdt-column hdt-g-col hdt-g-col-{{ block.settings.column_mb }} md:hdt-g-col-{{ block.settings.column_tb }} lg:hdt-g-col-{{ block.settings.column_dk }} {{ block.settings.rounded }} hdt-text-{{ block.settings.alignment_mb }} md:hdt-text-{{ block.settings.alignment }} hdt-oh {{ hide_class }} hdt-place-self-{{ block.settings.block_position_mb }} md:hdt-place-self-{{ block.settings.block_position }}" {{ block.shopify_attributes }}>
    {%- liquid
      assign image_background = block.settings.background_image
      if image_background != blank
        echo image_background | image_url: width: image_background.width | image_tag: width: image_background.width, height: image_background.height, alt: image_background.alt, class: 'hdt-full-width-link hdt-w-full hdt-h-full hdt-object-cover hdt-pe-none', loading: 'lazy'
      endif
    -%}
    <div class="hdt-column_inner hdt-place-self-{{ block.settings.content_position_mb }} md:hdt-place-self-{{ block.settings.content_position }} hdt-text-{{ block.settings.alignment_mb }} md:hdt-text-{{ block.settings.alignment }}" style="position: relative;z-index:2;">
      {% content_for 'blocks' %}
    </div>

  {% style %}
    #{{ block.id }}{
      --background-color: {{ block.settings.background_color }};
      --column-padding-mb: {{ block.settings.spacing_v_mb }}px {{ block.settings.spacing_h_mb }}px;
      --column-padding-tb: {{ block.settings.spacing_v_tb }}px {{ block.settings.spacing_h_tb }}px;
      --column-padding-dk: {{ block.settings.spacing_v_dk }}px {{ block.settings.spacing_h_dk }}px;
      align-content: {{ block.settings.align_content }};
    }
    #{{ block.id }} {
      background-color: var(--background-color);
      padding: var(--column-padding-mb);

      position: {{ block.settings.block_position_type_mb }};
      @media(min-width: 1150px) {
        position: {{ block.settings.block_position_type }};
      }
    }

    @media (min-width: 750px) {
      #{{ block.id }} {
        padding: var(--column-padding-tb);
      }
    }

    @media (min-width: 1150px) {
      #{{ block.id }} {
        padding: var(--column-padding-dk);
      }
    }

    {% if block.settings.max_content_width > 0 %}
      #{{ block.id }} > .hdt-column_inner {
        max-width: {{ block.settings.max_content_width }}px;
      }
    {% endif %}
    {% if block.settings.content_width > 0 %}
      #{{ block.id }} > .hdt-column_inner {
        width: {{ block.settings.content_width }}%;
      }
    {% endif %}
    {% if block.settings.custom_css != blank %}
      #{{ block.id }} {
        {{ block.settings.custom_css }}
      }
    {% endif %}
  {% endstyle %}
</div>
