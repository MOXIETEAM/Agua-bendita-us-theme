<!-- section/slideshow.liquid -->
{{ 'hdt-slideshow.css' | asset_url | stylesheet_tag }}
{%- style -%}#Slider-{{block.id}}{ {% if block.settings.image_height_mb=='adapt_image_first' or block.settings.image_height_mb=='fixed' %}--aspect-ratioapt:{% if block.settings.image_height_mb=='adapt_image_first' %}var(--slide-{{ block.blocks.first.id }}-ratio){% else %}{{block.settings.fixed_height_mb}}px{% endif %};{% endif %}{% if block.settings.image_height=='adapt_image_first' or block.settings.image_height=='fixed' %}--aspect-ratioapt-md:{% if block.settings.image_height=='adapt_image_first' %}var(--slide-{{ block.blocks.first.id }}-ratio-md){% else %}{{block.settings.fixed_height}}px{% endif %};{% endif %}}{%- endstyle -%}
<div class="hdt-s-inner" {%- unless block.index == 1 -%}hdt-reveal="fade-in"{%- endunless -%}>
  <hdt-slideshow {% if block.settings.is_fade %}isfade {% endif %}id="Slider-{{ block.id }}" autoheight class="hdt-slider hdt-relative hdt-container{% if block.settings.full_width %}-full{% endif %} hdt-slideshow hdt-slides-1 hdt-relative" config='{"loop": {{ block.settings.loop }}, "navUI": {{ block.settings.navUI }}, "dotUI": {{ block.settings.dotUI }}, "autoPlay": {{ block.settings.auto_play | times: 1000 }}, "pauseOnHover": {{ block.settings.pause_hover }}, "align": "center", "classNames": true, "autoHeight": true, "slidesToScroll": 1 }'>
    <div class="hdt-slider__viewport md:hdt-height--{{ block.settings.image_height }} hdt-height--{{ block.settings.image_height_mb }}">
      <div class="hdt-slider__container">
        {% content_for "blocks" %}
      </div>
    </div>
    {%- if block.settings.navUI == true -%}
      <div class="hdt-prev-next_wrap hdt-nav-{{ block.settings.nav_des }} hdt-full-width-link hdt-container-full hdt-pe-none hdt-flex hdt-justify-between hdt-align-center" color-scheme="{{ block.settings.color_scheme }}">
        <button aria-controls="Slider-{{ block.id }}" class="hdt-slider__button hdt-slider__button--prev hdt-inline-flex hdt-align-center hdt-justify-center{% if block.settings.nav_rounded_full %} hdt-rounded-full{% endif %} hdt-absolute hdt-left-0" name="previous"><svg xmlns="http://www.w3.org/2000/svg" width="7" height="11" viewBox="0 0 7 11" fill="currentColor">
          <path d="M5.5 11L0 5.5L5.5 0L6.47625 0.97625L1.9525 5.5L6.47625 10.0238L5.5 11Z"/>
        </svg></button>
        <button aria-controls="Slider-{{ block.id }}" class="hdt-slider__button hdt-slider__button--next hdt-inline-flex hdt-align-center hdt-justify-center{% if block.settings.nav_rounded_full %} hdt-rounded-full{% endif %} hdt-absolute hdt-right-0" name="next"><svg xmlns="http://www.w3.org/2000/svg" width="7" height="11" viewBox="0 0 7 11" fill="currentColor">
          <path d="M1.5 11L7 5.5L1.5 0L0.52375 0.97625L5.0475 5.5L0.52375 10.0238L1.5 11Z"/>
        </svg></button>
      </div>
    {%- endif -%}
    {%- if block.settings.dotUI == true -%}
      <div hdt-slider-dots aria-controls="Slider-{{ block.id }}" class="hdt-slider__dots hdt-slideshow-dots{% if block.settings.dot_vertical %} hdt-dot-vertical hdt-right-0 hdt-top-0 hdt-flex-col{%else%} hdt-container hdt-left-0 hdt-right-0{% endif %} hdt-slider__dots-{{ block.settings.dot_style }} hdt-pe-none hdt-inline-flex hdt-justify-{{ block.settings.dot_align }} hdt-absolute hdt-bottom-0" color-scheme="{{ block.settings.color_scheme }}" style="--dot-space:{{ block.settings.dot_space }}px;"></div>
    {%- endif -%}
  </hdt-slideshow>
</div>
{% schema %}
