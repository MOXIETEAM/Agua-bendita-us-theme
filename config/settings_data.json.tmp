                  "text_mBrn8t": {
                    "type": "text",
                    "name": "Text",
                    "settings": {
                      "text": "<p>For FW24, Agua by Agua Bendita is delighted to introduce Horizontes, an <br/>enthralling collection inspired by the soul of a woman who embarks on a northern <br/>voyage and passes through vast sky lines to cultivate a winter garden.</p><p><a href=\"https://us.aguabyaguabendita.com//collections/horizontes-collection\" title=\"Horizontes Collection\"><span style=\"text-decoration:underline\"><em><strong>SHOP NOW</strong></em></span></a></p>",
