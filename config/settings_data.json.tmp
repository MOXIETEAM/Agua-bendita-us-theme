                  "spacing_h_dk": 60,
                  "spacing_v_dk": 40,
                  "spacing_h_tb": 20,
                  "spacing_v_tb": 20,
                  "spacing_h_mb": 20,
                  "spacing_v_mb": 20,
                  "content_position": "center-start",
                  "content_position_mb": "center",
                  "alignment": "center",
                  "alignment_mb": "center",
                  "background_color": "#ffffff",
