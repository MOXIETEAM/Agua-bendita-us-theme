              "custom_css": ""
            },
            "blocks": {
              "multi_column_3mAA48": {
                "type": "_multi_column",
                "name": "Column",
                "settings": {
                  "hide_on_desktop": false,
                  "hide_on_mobile": false,
                  "column_dk": "12",
                  "column_tb": "12",
                  "column_mb": "12",
                  "spacing_h_dk": 0,
                  "spacing_v_dk": 0,
                  "spacing_h_tb": 0,
                  "spacing_v_tb": 0,
                  "spacing_h_mb": 0,
                  "spacing_v_mb": 0,
                  "content_position": "center",
                  "content_position_mb": "center",
                  "alignment": "center",
                  "alignment_mb": "center",
                  "background_color": "#ffffff",
                  "rounded": "none",
                  "max_content_width": 0,
                  "content_width": 100,
                  "align_content": "center"
                },
                "blocks": {
                  "heading_q8pLVJ": {
                    "type": "heading",
                    "settings": {
                      "heading": "",
                      "raw_heading": "<p style=\"letter-spacing:2.5px; font-size:20px; font-weight:300; font-style:italic;\"> MEET </p><br>   <h1 style=\"color: #f57373; font-weight:500; font-size:35px; letter-spacing:3.5px;margin-block-start: 0;\">MARI &amp; CATA</h1>",
                      "hidden_br_mobile": false,
                      "hidden_on_desktop": false,
                      "hidden_on_mobile": false,
                      "font_family_type": "body",
                      "text_transform": "uppercase",
                      "text_align": "none",
                      "text_align_mb": "none",
                      "heading_size": "h_custom",
                      "letter_spacing": 0,
                      "line_height": 1,
                      "text_color": "hdt-s-text",
                      "specific_text_color": "",
                      "font_size_heading_lg": 16,
                      "font_size_heading_md": 16,
                      "font_size_heading": 16,
                      "font_weight_heading": 700
                    },
                    "blocks": {}
                  },
                  "spacer_DLBxbG": {
                    "type": "spacer",
                    "name": "Spacer",
                    "settings": {
                      "direction": false,
                      "space_lg": 20,
                      "space_md": 20,
                      "space": 20
                    },
                    "blocks": {}
                  },
                  "text_mBrn8t": {
                    "type": "text",
                    "name": "Text",
                    "settings": {
                      "text": "",
                      "raw_text": "In 2003, best friends Catalina Álvarez and Mariana Hinestroza merged their <br> \npassions for fashion and design. They started working day and night to bring <br>\nto life a dream they had, creating Agua Bendita, the company's first brand.\n<br><br>\nIt started by making bathing suits for their friends and family using Catalina's <br>\ngrandmother's sewing machine and discarded fabrics they obtained during a <br> visit to a local clothing factory. Here, Agua Bendita's journey began.\n\n<br><br><br>\n\n<style> .landing-page .module.module-heading .caption { max-width:1200px !important; margin:30px auto; } \n\n@media screen and (min-width:767px) {\n    #shopify-section-page-about-founders .module.module-heading .headlines-wrap .caption > div {\n        padding-bottom: 40% !important;\n    }\n}\n</style>\n\n <div style=\"position:relative;    padding-bottom: 54%;margin: 0;\"> <iframe style=\"left:0;top:0;border:none;width: 100%;    height: 100%;position: absolute;\" src=\"https://player.vimeo.com/video/882617343?badge=0&amp;autopause=0&amp;player_id=0&amp;app_id=58479\"> </iframe> </div>\n\n<br><br>",
                      "hidden_br_mobile": true,
                      "hidden_on_desktop": false,
                      "hidden_on_mobile": true,
                      "text_align": "center",
                      "text_align_mb": "none",
                      "text_size": "custom",
                      "letter_spacing_text": 0,
                      "line_height": 1.4,
                      "space_bt_title": 15,
                      "space_bt_paragraph": 15,
                      "text_color": "hdt-s-text",
                      "specific_text_color": "",
                      "text_color_link": "#c9a564",
                      "max_width": 0,
                      "font_family_type": "body",
                      "font_size_text_lg": 14,
                      "font_size_text_md": 14,
                      "font_size_text": 14,
                      "font_weight_text": 300,
                      "force_custom_size": false
                    },
                    "blocks": {}
                  },
                  "text_bcyddz": {
                    "type": "text",
                    "name": "Text",
                    "settings": {
                      "text": "",
                      "raw_text": "In 2003, best friends Catalina Álvarez and Mariana Hinestroza merged their passions for fashion and design. They started working day and night to bring to life a dream they had, creating Agua Bendita, the company's first brand.\n<br><br>\nIt started by making bathing suits for their friends and family using Catalina's grandmother's sewing machine and discarded fabrics they obtained during a visit to a local clothing factory. Here, Agua Bendita's journey began.\n\n<br><br><br>\n\n<style> .landing-page .module.module-heading .caption { max-width:1200px !important; margin:30px auto; } \n\n@media screen and (min-width:767px) {\n    #shopify-section-page-about-founders .module.module-heading .headlines-wrap .caption > div {\n        padding-bottom: 40% !important;\n    }\n}\n</style>\n\n <div style=\"position:relative;    padding-bottom: 54%;margin: 0;\"> <iframe style=\"left:0;top:0;border:none;width: 100%;    height: 100%;position: absolute;\" src=\"https://player.vimeo.com/video/882617343?badge=0&amp;autopause=0&amp;player_id=0&amp;app_id=58479\"> </iframe> </div>\n\n<br><br>\n\nIn 2007, they became one of the first Colombian companies to export local fashion, paving the way for the hundreds that would follow in their footsteps. Thanks to the unique handmade designs, Agua Bendita quickly developed into a leading brand in Colombia, with thirty stores nationwide. Today, the label is also present in over fifty countries worldwide.\n\n<br><br>\n\nThanks to the unique handmade designs, Agua Bendita quickly developed into a leading brand in Colombia, with thirty stores nationwide. Today, the label is also present in over fifty countries worldwide.",
                      "hidden_br_mobile": false,
                      "hidden_on_desktop": true,
                      "hidden_on_mobile": false,
                      "text_align": "center",
                      "text_align_mb": "none",
                      "text_size": "custom",
                      "letter_spacing_text": 0,
                      "line_height": 1.4,
                      "space_bt_title": 15,
                      "space_bt_paragraph": 15,
                      "text_color": "hdt-s-text",
                      "specific_text_color": "",
                      "text_color_link": "#c9a564",
                      "max_width": 0,
                      "font_family_type": "body",
                      "font_size_text_lg": 14,
                      "font_size_text_md": 14,
                      "font_size_text": 14,
                      "font_weight_text": 300,
                      "force_custom_size": false
                    },
                    "blocks": {}
                  }
                },
                "block_order": [
                  "heading_q8pLVJ",
                  "spacer_DLBxbG",
                  "text_mBrn8t",
                  "text_bcyddz"
