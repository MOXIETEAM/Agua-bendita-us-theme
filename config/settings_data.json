                "blocks": {
                  "text_8mV7qx": {
                    "type": "text",
                    "name": "Text (Desktop)",
                    "settings": {
                      "text": "",
                      "raw_text": "<img src=\"https://cdn.shopify.com/s/files/1/0598/7831/0042/files/logo-summer-collection-2024.png?v=1707243801\" class=\"summer-collection-logo\" style=\"max-width: 180px; margin: 0 auto;\"><br><br>\n<img src=\"https://cdn.shopify.com/s/files/1/0598/7831/0042/files/Title-Summer-2024-returning-to-the-roots.png?v=1707266645\"><br>\n\n<p style=\"color:#000; padding: 0px 20px 15px\">Regeneration inspired by a change centered on the human being and expanded to collective thinking. The uncertainty of our times makes us reflect on the future. Agua Bendita invites us to celebrate and live with intention what unites us: people, places, customs, cultures, and communities. Wrapped in the sun, caressed by the breeze, bathed by the sea, and with bare feet on the earth, in the summer, we reconnect with nature.</p>",
                      "hidden_br_mobile": false,
                      "hidden_on_desktop": false,
                      "hidden_on_mobile": false,
                      "text_align": "none",
                      "text_align_mb": "none",
                      "text_size": "custom",
