                  "heading_QweYj6": {
                    "type": "heading",
                    "settings": {
                      "heading": "<p><strong>Where did your love for art come from?</strong></p>",
                      "raw_heading": "",
                      "hidden_br_mobile": false,
                      "hidden_on_desktop": false,
