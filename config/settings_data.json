                  "spacing_v_tb": 0,
                  "spacing_h_mb": 0,
                  "spacing_v_mb": 0,
                  "content_position": "center",
                  "content_position_mb": "center",
                  "alignment": "left",
                  "alignment_mb": "left",
                  "background_color": "#ffffff",
