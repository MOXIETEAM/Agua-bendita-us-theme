                  "heading_7WMwzQ": {
                    "type": "heading",
                    "settings": {
                      "heading": "<p><strong>What inspired you to design this collaboration?</strong></p>",
                      "raw_heading": "",
                      "hidden_br_mobile": false,
                      "hidden_on_desktop": false,
