                      "heading": "",
                      "raw_heading": "<h4 style=\"font-size:20px; font-weight:300; font-style:italic;\">THE STORY BEHIND THE STORY</h4>\n<h1 style=\"color: #FDD039; font-weight:500; font-size:30px; letter-spacing:3.5px;\"> AB SOUL</h1>",
