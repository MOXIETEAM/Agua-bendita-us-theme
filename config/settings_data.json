                  "heading_cJ7Gge": {
                    "type": "heading",
                    "settings": {
                      "heading": "<p><strong>What values do you share with Agua by Agua Bendita?</strong></p>",
                      "raw_heading": "",
                      "hidden_br_mobile": false,
                      "hidden_on_desktop": false,
                      "hidden_on_mobile": false,
                      "text_transform": "uppercase",
                      "text_align": "center",
                      "text_align_mb": "center",
                      "heading_size": "h_custom",
                      "letter_spacing": 2,
                      "line_height": 1.4,
                      "text_color": "hdt-s-text",
                      "specific_text_color": "",
                      "font_size_heading_lg": 16,
                      "font_size_heading_md": 16,
                      "font_size_heading": 16,
