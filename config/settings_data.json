                      "font_size_text_md": 14,
                      "font_size_text": 14,
                      "font_weight_text": 400,
                      "force_custom_size": false
                    },
                    "blocks": {}
                  },
                  "text_bnFniD": {
                    "type": "text",
                    "name": "Text (Mobile)",
                    "disabled": true,
                    "settings": {
                      "text": "",
                      "raw_text": "<style>\n@media(max-width: 767px) {\n  #summer-collection-logo-mb {\n    max-width: 180px;\n    margin: 0 auto;\n  }\n}\n</style>\n<img src=\"https://cdn.shopify.com/s/files/1/0598/7831/0042/files/logo-collection-resort-2025.png?v=1722976510\" class=\"summer-collection-logo\" id=\"summer-collection-logo-mb\"><br>\n\n\n<p style=\"color:#000; \npadding: 0px 10px 15px;\">As the sun rises over the French Riviera, four friends awake in their holiday home to the calls of seagulls. They dive into the pool, bask in the sun, and laugh together under the clear sky. Wandering through charming coastal villages and relaxing on sunlit beaches, they enjoy the salty breeze and rhythmic waves. As night falls, they dance to the ocean’s melody, savoring the freedom of summer and the magic of friendship. Join our circle and experience the magic of friendship and the allure of coastal living.</p>",
                      "hidden_br_mobile": false,
                      "hidden_on_desktop": true,
