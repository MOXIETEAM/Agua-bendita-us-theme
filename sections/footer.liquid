<!-- sections/footer.liquid -->
{% comment %} {%- comment -%}{{ 'hdt-footer.css' | asset_url | stylesheet_tag }}{%- endcomment -%} {% endcomment %}
{% liquid
  if section.settings.active_from != blank
    assign from_dt = section.settings.active_from | date: "%s" | plus: 0
  else
    assign from_dt = 'now' | date: '%s' | minus: 1
  endif

  if section.settings.active_to != blank
    assign to_dt = section.settings.active_to | date: "%s" | plus: 0
  else
    assign to_dt = 'now' | date: '%s' | plus: 1
  endif

  assign now_dt = "now" | date: "%s" | plus: 0
%}

{% if from_dt <= now_dt and now_dt <= to_dt %}
  {%-liquid 
    assign hdt-cur-lang = false
  -%}
  {%- liquid
    capture hide_class
      render 'hide_desktop_mobile', hide_on_desktop: section.settings.hide_on_desktop, hide_on_mobile: section.settings.hide_on_mobile
    endcapture
  -%}
  <div class="hdt-section-inner hdt-section-{{ section.id }} hdt-footer hdt-s-gradient hdt-section-spacing {{ hide_class }}" color-scheme="{{ section.settings.color_scheme }}" style="--spacing_top:{{ section.settings.spacing_top }}px;" timeline hdt-reveal="fade-in">
    <div class="hdt-footer-main hdt-border_{{ section.settings.border-f }} hdt-border_{{ section.settings.border-ps_main }} hdt-relative" style="--padding-t-main:{{ section.settings.padding-t-main }}px; --padding-bt-main:{{ section.settings.padding-bt-main }}px;">
      <div class="hdt-container {%- if section.settings.section_fullwidth -%}-full hdt-px-15{%- endif -%}">
        {%- liquid
          if section.blocks.size > 0
            assign footer_grid = section.blocks.size
          endif
        -%}
        <custom-footer-accordions>
          <div class="hdt-footer-menus hdt-footer-collapse-{{ section.settings.collapse }} hdt-grid-cols-1 hdt-footer-column" style="--spacing-y:0px;--spacing-x:0px;">
            {% content_for 'blocks' %}
          </div>
        </custom-footer-accordions>
        <div class="hdt-footer-info">
          <div class="hdt-info-item-signup-newsletter">
            {% content_for 'block', type: 'signup-newsletter-button', id: 'signup-newsletter-button' %}
          </div>
          <div class="hdt-info-item-store-locator">
            {% content_for 'block', type: '_store-locator', id: 'store-locator'%}
          </div>
          <div class="hdt-info-item-socials">
            {% content_for 'block', type: '_custom-socials', id: 'custom-socials'%}
          </div>
        </div>
      </div>
      <div class="hdt-info-item-copyright hdt-flex hdt-flex-col">
        {% content_for 'block', type: '_copyright', id: 'copyright' %}
        {% content_for 'block', type: '_footer-slim-menu', id: 'footer-slim-menu' %}
      </div>
    </div>
    {% comment %}
    <div class='hdt-footer-bottom'>
      <div class="hdt-container {%- if section.settings.section_fullwidth -%}-full hdt-px-15{%- endif -%}">
        <div class="hdt-footer-content-bottom">
          <div class="hdt-row-grid {% if section.settings.text_copR != blank and section.settings.svg != blank or section.settings.text_copR != blank and section.settings.image-svg_list != blank  %}md:hdt-grid-cols-2 hdt-grid-cols-1 {% else %}  hdt-grid-cols-1 {% endif %} hdt-align-center hdt-footer-bt-bar">
            {%- if section.settings.text_copR != blank -%}
              <div class=" hdt-footer-copyright hdt-flex hdt-flex-col {% if section.settings.text_copR != blank and section.settings.svg != blank or section.settings.text_copR != blank and section.settings.image-svg_list != blank %} md:hdt-align-start hdt-align-center hdt-align-start {% else %} hdt-justify-center hdt-align-center {% endif %} hdt-s-text2 {{ section.settings.text_size }}">
                <div class =" hdt-list-toleft hdt-flex hdt-flex-col hdt-text-center md:hdt-text-start">
                  {%- assign now_y = 'now' | date: '%Y' -%}
                  <div class="hdt-coppy-right"> 
                      {{- section.settings.text_copR | replace: "[year]", now_y -}}
                  </div>
                  {%- if section.settings.show_policy == true -%}
                    <ul class="hdt-policies hdt-row-flex md:hdt-justify-start hdt-justify-center">
                      {%- for policy in shop.policies -%}
                        {%- if policy != blank -%}
                          <li class="hdt-inline-flex"><a href="{{ policy.url }}">{{ policy.title }}</a></li>
                        {%- endif -%}
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </div>
                {%- if hdt-cur-lang == false -%}
                  {%- if section.settings.show_currency == true or section.settings.show_language == true -%}
                    <div class="hdt-footer-cur hdt-flex">
                      {%- if section.settings.show_currency -%}
                        {%- unless localization.available_countries.size <= 1 and settings.currency_type == "1" -%}
                        <div data-currency-wrap="" class="hdt-footer__currencies hdt-inline-block">
                          {%- render 'hdt_currency' -%}
                        </div>
                        {%- endunless -%}
                      {%- endif -%}
                      {%- if section.settings.show_language and localization.available_languages.size > 1 -%}
                        <div data-locale-wrap="" class="hdt-footer__languages hdt-inline-block">
                          {%- render 'hdt_language' -%}
                        </div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                {%- endif -%}
              </div>
            {%- endif -%}
            <div class="hdt-footer-bottom-menu">
              {%- assign footer_slim_linklist = settings.slim_linklist -%}
              {%- if linklists[footer_slim_linklist].links.size > 0 -%}
                {%- for link in linklists[footer_slim_linklist].links -%}
                  <a class="link" href="{{ link.url }}">{{ link.title }}</a>
                {%- endfor -%}
              {%- endif -%}
              <a class="link build-by" href="https://jumpdigital.co" target="_blank" title="Visit Jump Digital - Opens in a new tab">Built by Jump Digital</a>
            </div>
            {%- if section.settings.svg != blank -%}
              <div class="hdt-footer-payments hdt-flex hdt-flex-col {% if section.settings.text_copR != blank and section.settings.svg != blank or section.settings.text_copR != blank and section.settings.image-svg_list != blank %} md:hdt-align-end hdt-align-center {% else %} hdt-justify-center hdt-align-center {% endif %}">
                {%- assign arr = section.settings.svg | remove: ' ' | split: "," -%}
                <div class="hdt-payment-footer-svg hdt-pr hdt-flex lg:hdt-justify-end hdt-justify-center" style="--height-img:{{ section.settings.height }}px">
                  {%- for img in arr -%}
                    {%- if img contains 'cust4__' -%}
                      {%- assign getIMG = img | remove_first: "cust4__" -%}
                      {%- assign image = images[getIMG] -%}
                      {%- if image == blank -%}{%- continue -%}{%- endif -%}
                      <img loading="lazy" class="lazyloadhdt" src="https://cdn.shopify.com/s/assets/payment_icons/generic-dfdcaf09b6731ca14dd7441354c0ad8bc934184eb15ae1fda6a6b9e307675485.svg" data-src="{{ image | image_url: width: 100 }}" width="{{ image.width }}" height="{{ image.height }}"  alt="{{ image.alt | escape }}" />
                    {%- else -%}
                      <img loading="lazy" class="lazyloadhdt" src="{{ img | payment_type_img_url }}" width="{{ img.width }}" height="{{ img.height }}"  alt="{{ img | replace: '_', ' ' }}" />
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
            {%-else -%}
              {%- if section.settings.image-svg_list != blank -%}
                <div class="hdt-footer-payments hdt-flex hdt-flex-col {% if section.settings.text_copR != blank and section.settings.svg != blank or section.settings.text_copR != blank and section.settings.image-svg_list != blank %} md:hdt-align-end hdt-align-center {% else %} hdt-justify-center hdt-align-center {% endif %}" style="--width-image_list:{{ section.settings.width-image_list }}px">
                  {%- capture size -%}
                  {{ section.settings.width-image_list }}px
                    {%- endcapture -%}
                  {%- capture width -%}
                    {{ section.settings.width-image_list }}, {{ section.settings.width-image_list | times: 2 }}
                    {%- endcapture -%}
                    <div class="hdt-inline-flex hdt-align-center">
                    {{ section.settings.image-svg_list | image_url: width: section.settings.image-svg_list.width | image_tag: loading: 'lazy', width: section.settings.image-svg_list.width, height: section.settings.image-svg_list.height, class: 'hdt-full-image hdt-obj-eff md:hdt-block', sizes: size, widths: width }}
                    </div>
                </div>
              {%- endif -%}
            {%- endif -%}
            {%- if section.settings.enable_follow_on_shop -%}
              <div class="hdt-footer__follow-on-shop">
                {{ shop | login_button: action: 'follow' }}
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
    {% endcomment %}
  </div>
  {%- if use_newsletter -%}
    {{ 'newsletter.css' | asset_url | stylesheet_tag }}
  {%- endif -%}
  {%- if use_social -%}
    {{ 'hdt-icon-social.css' | asset_url | stylesheet_tag }}
  {%- endif -%}
  {%- style -%}#shopify-section-{{section.id}}{--section-pt:{{section.settings.padding_top}}px;--section-pb:{{section.settings.padding_bottom}}px;--section-prate:{{section.settings.padding_rate}}}.hdt-footer .hdt-heading-f{--mg-bt-heading:{{section.settings.spacing_bt_heading}}px}@media(max-width:1150px){.hdt-list-toleft{flex-direction:column}.hdt-list-toleft .hdt-policies li{margin:0}}@media only screen and (max-width :1024px){.hdt-footer-collapse-true .hdt-heading-f{cursor:pointer}.hdt-footer-collapse-true .hdt-collapse-icon{margin-inline-end:1rem}.hdt-footer-collapse-true .hdt-heading-f .hdt-collapse-icon:after,.hdt-footer-collapse-true .hdt-heading-f .hdt-collapse-icon:before{position:absolute;content:"";background-color:rgb(var(--color-foreground));transform:translate(-50%,-50%) rotate(-90deg);top:50%;left:50%;transition:transform .25s ease-in-out,opacity .25s ease-in-out,-webkit-transform .25s ease-in-out}.hdt-footer-collapse-true .hdt-heading-f .hdt-collapse-icon:after{width:1px;height:12px}.hdt-footer-collapse-true .hdt-heading-f .hdt-collapse-icon:before{width:12px;height:1px}.hdt-footer-collapse-true .open .hdt-heading-f .hdt-collapse-icon:after{transform:translate(-50%,-50%) rotate(90deg)}.hdt-footer-collapse-true .open .hdt-heading-f .hdt-collapse-icon:before{opacity:0}.hdt-footer-collapse-true .hdt-col-block .hdt-collapse-content{height:0;overflow:hidden;transition:height 0.25s ease-out}.hdt-footer-collapse-true .hdt-col-block.open .hdt-collapse-content{max-height:auto;transition:height 0.25s ease-in-out 0s!important}}@media(min-width:1150px){.hdt-custom_width .hdt-col{flex:0 0 auto;max-width:100%;width:var(--cus-width)}}.hdt-footer-section .hdt-policies{gap:10px} .hdt-footer-payments img{width:var(--width-image_list);}{%- endstyle -%}
{% endif %}
{% schema %}
{
  "name": "t:sections.footer.name",
  "class": "hdt-section-group hdt-footer-section",
  "limit": 1,
  "enabled_on": {
    "groups": [
      "footer"
    ]
  },
  "settings": [
    {
      "id": "hide_on_desktop",
      "type": "checkbox",
      "label": "Hide on desktop",
      "default": false
    },
    {
      "id": "hide_on_mobile",
      "type": "checkbox",
      "label": "Hide on tablet, mobile",
      "default": false
    },
    {
      "id": "active_from",
      "label": "Active from (YYYY-MM-DD HH:MM:SS)",
      "type": "text",
      "placeholder": "Optional"
    },
    {
      "id": "active_to",
      "label": "Active up to (YYYY-MM-DD HH:MM:SS)",
      "type": "text",
      "placeholder": "Optional"
    },
    {
      "type": "checkbox",
      "id": "collapse",
      "label": "t:sections.footer.settings.collapse.label",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header-main"
    },
    {
      "type": "select",
      "id": "border-f",
      "default": "none",
      "label": "t:sections.footer.settings.border-f.label",
      "options": [
        {
          "value": "none",
          "label": "t:sections.footer.settings.border-f.option_1"
        },
        {
          "value": "top",
          "label": "t:sections.footer.settings.border-f.option_2"
        },
        {
          "value": "bottom",
          "label": "t:sections.footer.settings.border-f.option_3"
        },
        {
          "value": "top-bottom",
          "label": "t:sections.footer.settings.border-f.option_4"
        }
      ]
    },
    {
      "type": "select",
      "id": "border-ps_main",
      "default": "container",
      "label": "t:sections.footer.settings.border-ps_main.label",
      "options": [
        {
          "value": "fulwidth",
          "label": "t:sections.footer.settings.border-ps_main.option_1"
        },
        {
          "value": "container",
          "label": "t:sections.footer.settings.border-ps_main.option_2"
        }
      ]
    },
    {
      "type": "select",
      "id": "heading_fs",
      "label": "t:sections.footer.settings.heading_fs.label",
      "default": "hdt-text-base",
      "options": [
        {
          "value": "hdt-text-base",
          "label": "t:sections.footer.settings.heading_fs.option_1"
        },
        {
          "value": "hdt-text-lg",
          "label": "t:sections.footer.settings.heading_fs.option_2"
        },
        {
          "value": "hdt-text-xl",
          "label": "t:sections.footer.settings.heading_fs.option_3"
        }
      ]
    },
    {
      "type": "select",
      "id": "text_weight",
      "label": "Heading font weight",
      "default": "hdt-font-medium",
      "options": [
        {
          "value": "hdt-font-normal",
          "label": "Normal"
        },
        {
          "value": "hdt-font-medium",
          "label": "Medium"
        },
        {
          "value": "hdt-font-extrabold",
          "label": "Extrabold"
        },
        {
          "value": "hdt-font-bold",
          "label": "Bold"
        }
      ]
    },
    {
      "type": "range",
      "id": "spacing_bt_heading",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.footer.settings.spacing_bt_heading",
      "default": 30
    },
    {
      "type": "select",
      "id": "text_size",
      "label": "t:sections.footer.settings.text_size.label",
      "default": "hdt-text-base",
      "options": [
        {
          "value": "hdt-text-base",
          "label": "t:sections.footer.settings.text_size.option_1"
        },
        {
          "value": "hdt-text-lg",
          "label": "t:sections.footer.settings.text_size.option_2"
        },
        {
          "value": "hdt-text-xl",
          "label": "t:sections.footer.settings.text_size.option_3"
        }
      ]
    },
    {
      "type": "range",
      "id": "padding-t-main",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding top main",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-bt-main",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding bottom main",
      "default": 40
    },
    {
        "type": "text",
        "id": "newletter_title",
        "label": "Newsletter Title",
        "default": "Subscribe to our Newsletter"
    },
    {
      "type": "textarea",
      "id": "svg",
      "label": "t:sections.footer.settings.svg.label",
      "default": "amazon_payments,american_express,apple_pay,bitcoin",
      "info": "t:sections.footer.settings.svg.info"
    },
    {
      "type": "number",
      "id": "height",
      "label": "t:sections.footer.settings.height",
      "default": 30
    },
    {
      "type":"image_picker",
      "id":"image-svg_list",
      "label": "t:sections.footer.settings.image-svg_list"
    },
    {
      "type": "number",
      "id": "width-image_list",
      "label": "t:sections.footer.social_media.settings.image_w",
      "default": 200
    },
    {
      "type": "header",
      "content": "Follow on Shop",
      "info": "t:sections.footer.settings.follow_on_shop.info"
    },
    {
      "type": "checkbox",
      "id": "enable_follow_on_shop",
      "default": false,
      "label": "t:sections.footer.settings.enable_follow_on_shop.label"
    },
    {
      "type": "header",
      "content": "Country/region selector",
      "info": "t:sections.footer.settings.contry_region.info"
    },
    {
      "type": "checkbox",
      "id": "show_currency",
      "default": true,
      "label": "t:sections.footer.settings.show_currency.label"
    },
    {
      "type": "header",
      "content": "Language selector",
      "info": "t:sections.footer.settings.language_selector.info"
    },
    {
      "type": "checkbox",
      "id": "show_language",
      "default": true,
      "label": "t:sections.footer.settings.show_language.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section_layout"
    },
    {
      "type": "checkbox",
      "id": "section_fullwidth",
      "label": "t:sections.all.section_fullwidth",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "spacing_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top margin",
      "default": 30
    },
    {
      "type": "header",
      "content": "Padding section"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.title.settings.padding_top.label",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.title.settings.padding_bottom.label",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_rate",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:sections.all.padding.padding_rate",
      "default": 75
    }
  ],
  "blocks": [
    {"type": "_footer-menu"},
  ],
  "presets": [
    {
      "name": "t:sections.footer.presets.name",
      "blocks": [
        {"type": "_footer-menu" },
      ],
    }
  ]
}
{% endschema %}
