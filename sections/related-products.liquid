<!-- related-products.liquid -->

{%- liquid
  assign current_width = settings.page_width | append: 'px'
  assign current_width_tb = '100vw'
  assign current_width_mb = '100vw'
  assign space_item = "30px"
  assign space_item_tb = "15px"
  assign space_item_mb = "15px" 

  if section.settings.section_fullwidth
    if section.settings.boxed_fullwidth
      assign current_width = '100vw - 80px'
      assign current_width_tb = '100vw - 40px'
      assign current_width_mb = '100vw - 10px'
    else
      assign current_width = '100vw'
    endif
  endif

  assign color_list = 'products.theme_settings.color' | t | downcase | strip | replace: ' ,', ',' | replace: ', ', ',' | split: ',' | uniq
  assign size_list = 'products.theme_settings.size' | t | downcase | strip | replace: ' ,', ',' | replace: ', ', ',' | split: ',' | uniq 

  assign is_available_recommend_products = false

  if section.settings.recommend_method == "shopify"
    assign recommend_products = recommendations.products
    if recommendations.performed and recommendations.products_count
      assign is_available_recommend_products = true
    endif
  else
    comment
    if product.metafields.pdp.recommended != blank
      assign placeholder_arr = "" | split: ""
      assign recommend_products = placeholder_arr
      assign product_handles = product.metafields.pdp.recommended | split: ","
      for handle in product_handles
        unless handle.size > 0
          continue
        endunless
        assign product_item = all_products[handle]
        if product_item != blank and product_item.available
          assign single_product_arr = product_item | sort
          assign recommend_products = recommend_products | concat: single_product_arr
        endif
      endfor
    elsif collection.products
      assign recommend_products = collection.products
    endif

    if recommend_products.size > 0
      assign is_available_recommend_products = true
    endif
    endcomment

    if product.metafields['globals']['related'] != blank
      assign reco_collection = collections[ product.metafields['globals']['related'] ]
      assign col_product_count = reco_collection.products_count | times:1
    elsif collection.products
      assign reco_collection = collection
      assign col_product_count = collection.products_count | times:1
    endif

    if col_product_count > 0
      assign is_available_recommend_products = true
    endif

    assign recommend_products = reco_collection.products

  endif
-%}
{%- capture sizes -%}
  (min-width: 1150px) calc(({{ current_width }} -  ({{ space_item }} * ( {{ section.settings.col_dk }} - 1 ))) * 1 / {{ section.settings.col_dk }}),(min-width: 768px) calc( ({{ current_width_tb }} - ({{ space_item_tb }} * ( {{ section.settings.col_tb }} - 1 ))) * 1 / {{ section.settings.col_tb }}), calc( ({{ current_width_mb }} - ({{ space_item_mb }} * ( {{ section.settings.col_mb }} - 1 ) )) * 1 / {{ section.settings.col_mb }})
{%- endcapture -%}
<div id="{{ section.id }}" class="hdt-s-gradient hdt-section-spacing" color-scheme="{{ section.settings.color_scheme }}">
  {% if section.settings.enable_top_divider %}
    <div class="hdt-custom-divider"></div>
  {% endif %}
  <product-recommendations class="related-products" data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id | default: cart.items.first.product_id | default: collections.all.products.first.id }}&limit={{ section.settings.limit }}&type=product">
    {%- if is_available_recommend_products -%}
      <div class="hdt-container{%- if section.settings.full_width -%}-full{% endif %}">
        {%- render 'section-top-head' -%}
        {% liquid
          assign products_size = recommend_products.size

          assign center_slider_items_dk = false
          assign col_dk = section.settings.col_dk | plus: 0
          if products_size < col_dk
            assign center_slider_items_dk = true
          endif

          assign center_slider_items_tb = false
          assign col_tb = section.settings.col_tb | plus: 0
          if products_size < col_tb
            assign center_slider_items_tb = true
          endif

          assign center_slider_items_mb = false
          assign col_mb = section.settings.col_mb | plus: 0
          if products_size < col_mb
            assign center_slider_items_mb = true
          endif
        %}
        <hdt-slider id="Slider-{{ section.id }}" class="hdt-collection-products hdt-slider__products hdt-collection-has-pr{{ section.settings.product_des }} hdt-slider hdt-slider-parent hdt-slide-spacing-x hdt-relative {% if section.settings.navUI %}hdt-slider-has-nav hdt-nav-btns-{{ section.settings.nav_des }} hdt-nav-shape_{{ section.settings.nav_shape }} hdt-nav-{{ section.settings.nav_pos }} hdt-nav-{{ section.settings.nav_size }} hdt-slider-btn-vi-{{ section.settings.btn_vi }}{% endif %} {% if section.settings.dotUI %} hdt-slider-has-dots-dk{% endif %} hdt-slider__dots_outline hdt-ratio--{{ section.settings.image_ratio }} {% unless section.settings.image_size %} hdt-ratio--contain{% endunless %} lg:hdt-slides-{{ section.settings.col_dk }} md:hdt-slides-{{ section.settings.col_tb }} hdt-slides-{{ section.settings.col_mb }}{% if center_slider_items_dk %} center-items-dk{% endif %}{% if center_slider_items_tb %} center-items-tb{% endif %}{% if center_slider_items_mb %} center-items-mb{% endif %}" config='{ "dotUI": true, "navUI": {{ section.settings.navUI }}, "navUICenter":true }'>
          <div class="hdt-slider__viewport hdt-relative">
            <div class="hdt-slider__container">
              {%- liquid
                case section.settings.product_des
                  when '2'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0' and section.settings.show_wishlist
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'right'
                      endif
                    endcapture
                     for product in recommend_products limit: section.settings.limit
                      unless settings.remove_collection_url
                        assign product_url = product.url | within: section.settings.collection
                      endunless
                      render 'card-product2', card_product: product, class: "hdt-slider__slide hdt-pr-style2", section_id: section.id, sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: section.settings.show_vendor, show_alt_image: section.settings.show_alt_image, show_quick_view: section.settings.show_quick_view
                    endfor
                  when '3'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0'
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'left'
                      endif
                    endcapture
                     for product in recommend_products limit: section.settings.limit
                      unless settings.remove_collection_url
                        assign product_url = product.url | within: section.settings.collection
                      endunless
                      render 'card-product3', card_product: product, class: "hdt-slider__slide hdt-pr-style3", section_id: section.id, sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: section.settings.show_vendor
                    endfor
                  when '4'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0'
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'left'
                      endif
                    endcapture
                     for product in recommend_products limit: section.settings.limit
                      unless settings.remove_collection_url
                        assign product_url = product.url | within: section.settings.collection
                      endunless
                      render 'card-product4', card_product: product, class: "hdt-slider__slide hdt-pr-style4", section_id: section.id, sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: section.settings.show_vendor
                    endfor
                  when '5'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0'
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                      endif
                    endcapture
                     for product in recommend_products limit: section.settings.limit
                      unless settings.remove_collection_url
                        assign product_url = product.url | within: section.settings.collection
                      endunless
                      render 'card-product5', card_product: product, class: "hdt-slider__slide hdt-pr-style5", section_id: section.id, sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: section.settings.show_vendor
                    endfor
                  when '6'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0'
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                      endif
                    endcapture
                     for product in recommend_products limit: section.settings.limit
                      unless settings.remove_collection_url
                        assign product_url = product.url | within: section.settings.collection
                      endunless
                      unless settings.remove_collection_url
                        assign product_url = product.url | within: section.settings.collection
                      endunless
                      render 'card-product6', card_product: product, class: "hdt-slider__slide hdt-pr-style6", section_id: section.id, sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: section.settings.show_vendor
                    endfor
                  when '7'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0'
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                      endif
                    endcapture
                     for product in recommend_products limit: section.settings.limit
                      unless settings.remove_collection_url
                        assign product_url = product.url | within: section.settings.collection
                      endunless
                      render 'card-product7', card_product: product, class: "hdt-slider__slide hdt-pr-style7 hdt-relative", section_id: section.id, sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: section.settings.show_vendor
                    endfor
                  when '8'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0'
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                      endif
                    endcapture
                     for product in recommend_products limit: section.settings.limit
                      unless settings.remove_collection_url
                        assign product_url = product.url | within: section.settings.collection
                      endunless
                      render 'card-product8', card_product: product, class: "hdt-slider__slide hdt-pr-style8", section_id: section.id, sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: section.settings.show_vendor
                    endfor
                  when '9'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0'
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                      endif
                    endcapture
                     for product in recommend_products limit: section.settings.limit
                      unless settings.remove_collection_url
                        assign product_url = product.url | within: section.settings.collection
                      endunless
                      render 'card-product9', card_product: product, class: "hdt-slider__slide hdt-pr-style1 hdt-pr-style9", section_id: section.id, sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: section.settings.show_vendor
                    endfor
                  when '10'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0'
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                      endif
                    endcapture
                     for product in recommend_products limit: section.settings.limit
                      unless settings.remove_collection_url
                        assign product_url = product.url | within: section.settings.collection
                      endunless
                      render 'card-product10', card_product: product, class: "hdt-slider__slide hdt-pr-style1 hdt-pr-style10", section_id: section.id, sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: section.settings.show_vendor
                    endfor
                  when '11' or '12'
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0'
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                      endif
                    endcapture
                     for product in recommend_products limit: section.settings.limit
                      unless settings.remove_collection_url
                        assign product_url = product.url | within: section.settings.collection
                      endunless
                      render 'card-product11', card_product: product, section_id: section.id, class: "hdt-slider__slide hdt-pr-style1 hdt-pr-style11", sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: section.settings.show_vendor
                    endfor
                  when '13'
                     for product in recommend_products limit: section.settings.limit
                      capture btn_wishlist_code
                        if settings.wishlist_mode != '0' and section.settings.show_wishlist
                          render 'wishlisthero-collection-product', product: product
                        endif
                      endcapture
                      unless settings.remove_collection_url
                        assign product_url = product.url | within: section.settings.collection
                      endunless
                      render 'card-product13', card_product: product, class: "hdt-slider__slide hdt-pr-style4", section_id: section.id, sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: section.settings.show_vendor, show_alt_image: section.settings.show_alt_image, show_secondary_image: section.settings.show_secondary_image, show_quick_view: section.settings.show_quick_view, show_custom_size_selector: section.settings.show_custom_size_selector
                    endfor
                  else
                    capture btn_wishlist_code
                      if settings.wishlist_mode != '0' and section.settings.show_wishlist
                        render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
                      endif
                    endcapture
                     for product in recommend_products limit: section.settings.limit
                      unless settings.remove_collection_url
                        assign product_url = product.url | within: section.settings.collection
                      endunless
                      render 'card-product1', card_product: product, class: "hdt-slider__slide hdt-pr-style1", section_id: section.id, sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: section.settings.show_vendor, show_alt_image: section.settings.show_alt_image, show_quick_view: section.settings.show_quick_view
                    endfor
                endcase
              -%}
            </div>
          </div>
          {%- if section.settings.navUI -%}
            {%- render 'nav_slider', nav_des: section.settings.nav_des, nav_icon: section.settings.nav_icon -%}
          {%- endif -%}
          <div hdt-slider-dots aria-controls="Slider-{{ section.id }}" class="hdt-slider__dots hdt-flex hdt-align-center hdt-justify-center"></div>
        </hdt-slider>
      </div>
    {%- endif -%}
  </product-recommendations>
</div>
{%- style -%}#shopify-section-{{section.id}}{--section-pt:{{section.settings.padding_top}}px;--section-pb:{{section.settings.padding_bottom}}px;--section-prate:{{section.settings.padding_rate}}}{%- endstyle -%}
{% schema %}
