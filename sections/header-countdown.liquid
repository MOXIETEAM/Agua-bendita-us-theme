{%- assign has_text = section.settings.header_countdown_text -%}
{%- assign has_cta = section.settings.header_countdown_cta -%}
{%- assign has_link = section.settings.header_countdown_link -%}
{%- if
  has_text != blank
  and has_cta != blank
  and has_link != blank
  and section.settings.header_countdown_enable
  and section.settings.header_countdown_active_from != blank
  and section.settings.header_countdown_active_to != blank
-%}
  {{ 'hdt-header-countdown.css' | asset_url | stylesheet_tag }}

  {%- assign default_text = has_text -%}
  {%- assign mobile_text = default_text -%}
  {%- if section.settings.header_countdown_mobile_text != blank -%}
    {%- assign mobile_text = section.settings.header_countdown_mobile_text -%}
  {%- endif -%}

  {%- liquid
    capture hide_class
      render 'hide_desktop_mobile', hide_on_desktop: section.settings.hide_on_desktop, hide_on_mobile: section.settings.hide_on_mobile
    endcapture
  -%}

  <hdt-sticky-header sticky-type="always" prefix="header" class="{{ hide_class }}">
    <div
      class="header-countdown {{ section.settings.header_countdown_color }}"
      style="background-color: {{ section.settings.header_countdown_background }};"
      data-header-countdown-root
    >
      {%- if has_link != blank -%}
        <a href="{{ has_link }}" aria-label="{{ has_cta | escape }}"></a>
      {%- endif -%}

      <div class="countdown-mobile-text">{{ mobile_text }}</div>
      <div class="countdown-desktop-text">{{ default_text }}</div>

      <div
        class="countdown-timer"
        data-header-countdown-timer
        data-date-from="{{ section.settings.header_countdown_active_from | escape }}"
        data-date-to="{{ section.settings.header_countdown_active_to | escape }}"
      ></div>

      <div class="countdown-cta-wrapper" role="button">
        <button class="countdown-cta">
          <span>{{ has_cta }}</span>
        </button>
      </div>
    </div>
  </hdt-sticky-header>
  <script src="{{ 'header-countdown-custom.js' | asset_url }}" defer></script>
{%- endif -%}

{% schema %}
{
  "name": "Header Countdown",
  "class": "hdt-section-group hdt-section-header hdt-header-countdown",
  "limit": 1,
  "enabled_on": {
    "groups": [
      "header"
    ]
  },
  "settings": [
    {
      "id": "hide_on_desktop",
      "type": "checkbox",
      "label": "Hide on desktop",
      "default": false
    },
    {
      "id": "hide_on_mobile",
      "type": "checkbox",
      "label": "Hide on tablet, mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "Header Countdown"
    },
    {
      "type": "checkbox",
      "id": "header_countdown_enable",
      "label": "Enable?",
      "default": false
    },
    {
      "type": "color",
      "id": "header_countdown_background",
      "label": "Countdown background color",
      "default": "#000000"
    },
    {
      "type": "radio",
      "options": [
        {
          "value": "theme-dark",
          "label": "Light"
        },
        {
          "value": "theme-light",
          "label": "Dark"
        }
      ],
      "default": "theme-dark",
      "id": "header_countdown_color",
      "label": "Font Color"
    },
    {
      "id": "header_countdown_text",
      "label": "Subnav Banner Desktop Text (default)",
      "type": "text"
    },
    {
      "id": "header_countdown_mobile_text",
      "label": "Subnav Banner Mobile Text",
      "type": "text",
      "info": "Use a short text when countdown is enabled, no longer then 20 characters."
    },
    {
      "id": "header_countdown_link",
      "label": "Subnav Banner Link",
      "type": "url"
    },
    {
      "id": "header_countdown_cta",
      "label": "Subnav Banner CTA",
      "type": "text"
    },
    {
      "id": "header_countdown_active_from",
      "label": "Subnav Banner Active from (YYYY/MM/DD)",
      "info": "Optionally include time (HH:MM:SS), for example: YYYY/MM/DD HH:MM:SS. If omitted, assumes 00:00:00.",
      "type": "text",
      "placeholder": "Optional"
    },
    {
      "id": "header_countdown_active_to",
      "label": "Subnav Banner Active up to (YYYY/MM/DD)",
      "info": "Optionally include time (HH:MM:SS), for example: YYYY/MM/DD HH:MM:SS. If omitted, assumes 23:59:59.",
      "type": "text",
      "placeholder": "Optional"
    }
  ],
  "presets": [
    {
      "name": "Header Countdown"
    }
  ]
}
{% endschema %}
