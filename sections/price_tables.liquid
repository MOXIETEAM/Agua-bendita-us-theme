<!-- Price-table.liquid -->
{% liquid
  if section.settings.active_from != blank
    assign from_dt = section.settings.active_from | date: "%s" | plus: 0
  else
    assign from_dt = 'now' | date: '%s' | minus: 1
  endif

  if section.settings.active_to != blank
    assign to_dt = section.settings.active_to | date: "%s" | plus: 0
  else
    assign to_dt = 'now' | date: '%s' | plus: 1
  endif

  assign now_dt = "now" | date: "%s" | plus: 0
%}

{% if from_dt <= now_dt and now_dt <= to_dt %}
  {% comment %} {{ 'hdt-card-products.css' | asset_url | stylesheet_tag }} {% endcomment %}
  {{ 'hdt-price-tables.css' | asset_url | stylesheet_tag }}

  {%- liquid
    capture hide_class
      render 'hide_desktop_mobile', hide_on_desktop: section.settings.hide_on_desktop, hide_on_mobile: section.settings.hide_on_mobile
    endcapture
  -%}
  <div id="{{ section.id }}" class="hdt-section-spacing hdt-s-gradient {{ hide_class }}" style="--section-pt: {{ section.settings.padding_top }}px; --section-pb: {{ section.settings.padding_bottom }}px; --section-prate:{{ section.settings.padding_rate }};" color-scheme="{{ section.settings.color_scheme }}">
    <div class="hdt-container{%- if section.settings.section_fullwidth -%}-full{% endif %}">
      {%- content_for "block", type: "section-heading", id: "price-table" -%} 
      <div class="hdt-main-price-table">
        <hdt-slider id="Slider-{{ section.id }}" class="hdt-relative hdt-pr-style1 hdt-product-btns hdt-icon-check-{{ section.settings.enable_icon_check }} hdt-slider hdt-slider-parent hdt-slide-spacing-x {% if section.settings.navUI %}hdt-slider-has-nav hdt-nav-btns-default hdt-nav-middle_out{% endif %}{% if section.settings.dotUI %}
          hdt-slider-has-dots-dk{% endif %} hdt-slider__dots_outline lg:hdt-slides-{{ section.settings.col_dk }} md:hdt-slides-{{ section.settings.col_tb }} hdt-slides-{{ section.settings.col_mb }}" config='{ "id": "Slider-{{ section.id }}", "navUI": {{ section.settings.navUI }}, "dotUI": true, "navUICenter": true}' >
          <div class="hdt-slider__viewport hdt-relative">
            <div class="hdt-slider__container">
             {% content_for 'blocks' %}
            </div>
          </div>
          {%- if section.settings.navUI -%}
            {%- render 'nav_slider', nav_des: section.settings.nav_des -%}
          {%- endif -%}
          <div hdt-slider-dots class="hdt-slider__dots hdt-flex hdt-align-center hdt-justify-center no-js-hidden" aria-controls="Slider-{{ section.id }}" style="--dots-distance: 30px;"></div>
        </hdt-slider>
      </div>
    </div>
  </div>
{% endif %}
{% schema %}
  {
    "name": "t:sections.price-tables.name",
    "class": "hdt-section hdt-price-tables",
    "disabled_on": {
      "groups": [
        "*"
