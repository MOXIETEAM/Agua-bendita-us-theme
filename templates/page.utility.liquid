{{ 'hdt-accordion.css' | asset_url | stylesheet_tag }}

<div class="utility-page {{ page.handle }}">
    {% comment %}
    <div class="utility-banner">
        <p class="utility-title">{{ settings.utility_title }}</p>
    </div>
    {% endcomment %}
    {% comment %}
    <nav class="utility-nav">
        <div class="inner-wrapper links">
        {%- assign utility_nav_linklist = settings.utility_nav_linklist -%}
        {%- if linklists[utility_nav_linklist].links.size > 0 -%}
        
            {% assign navLinkHtml = '' %}
            {%- for link in linklists[utility_nav_linklist].links -%}
                {% if link.active %}
                    <span class="link select-link">{{ link.title }}</span>
                    {% assign activeLink = link %}
                {%- endif -%}
                
                {% capture navLinkHtmlItem %}
                    {%- if link.levels > 0 -%}
                    <div class="link-wrapper {% if link.active %}active{% endif %}">
                        <a class="link {% if link.active %}active{% endif %}" href="{{ link.url }}">{{ link.title }}</a>
                        <div class="sublinks {% if link.active %}active{% endif %}">
                        {% for sublink in link.links %}  
                            <a class="sublink" href="{{- link.url -}}#{{ sublink.title | handleize }}">{{ sublink.title }}</a>
                        {% endfor %}  
                        </div>
                    </div>
                    {%- else -%}
                    <a class="link {% if link.active %}active{% endif %}" href="{{ link.url }}">{{ link.title }}</a>    
                    {%- endif -%}
                {% endcapture %}
                {% assign navLinkHtml = navLinkHtml | append: navLinkHtmlItem %}
            {%- endfor -%}
    
            <div class="link-container">
                {{ navLinkHtml }}
            </div>
        {%- endif -%}    
        </div>
    </nav> 
    {% endcomment %}


    {% if page.metafields.custom.page_template != blank %}
        {% assign section_template = page.metafields.custom.page_template %}
        {% if section_template == 'page-utility-1' %}
          {% section 'page-utility-1' %}
        {% elsif section_template == 'page-utility-2' %}
          {% section 'page-utility-2' %}
        {% elsif section_template == 'page-utility-3' %}
          {% section 'page-utility-3' %}
        {% elsif section_template == 'page-utility-4' %}
          {% section 'page-utility-4' %}
        {% elsif section_template == 'page-utility-5' %}
          {% section 'page-utility-5' %}
        {% elsif section_template == 'page-utility-6' %}
          {% section 'page-utility-6' %}
        {% elsif section_template == 'page-utility-7' %}
          {% section 'page-utility-7' %}
        {% elsif section_template == 'page-utility-8' %}
          {% section 'page-utility-8' %}
        {% elsif section_template == 'page-utility-9' %}
          {% section 'page-utility-9' %}
        {% elsif section_template == 'page-utility-10' %}
          {% section 'page-utility-10' %}
        {% else %}
          {% render 'page_utility' %}
        {% endif %}
    {% else %}
      {% render 'page_utility' %}
    {% endif %}

    {% comment %}
    <div class="utility-content">
        <div class="inner-wrapper">
            <h1 class="utility-page-title">{{ page.title }}</h1>
            <div class="utility-page-content">
              {% assign separate_contents = page.content| split: '<h4>' %}

              {% for desc_content in separate_contents %}
                  {% assign separate_title = desc_content | split: '</h4>' %}
                  {% assign item_title = separate_title[0] %}
                  {% assign item_title_handle = item_title | handleize %}
                  {% assign item_content = separate_title[1] %}
                  
                  {%- assign item_title = item_title | replace: '<meta charset="utf-8">',''  -%}
                  {%- assign item_content = item_content | replace: '<meta charset="utf-8">',''  -%}

                  {% unless forloop.index == 1 and item_content == blank %}
                    <hdt-accordion class="hdt-custom-accordion__item">
                      <details>
                        <summary>
                          <span class="hdt-custom-accordion__title">{{ item_title }}</span>
                          <span class="hdt-custom-accordion__icon"></span>
                        </summary>
                        <div class="hdt-custom-accordion__content">{{ item_content }}</div>
                      </details>
                    </hdt-accordion>
                  {% else %}
                    {{item_title}}
                  {% endunless %}
              {% endfor %}
            </div>
        </div>
    </div>
    {% endcomment %}
</div>
