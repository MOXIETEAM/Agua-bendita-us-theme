{%- comment -%}
  Renders a size list

  Accepts:
  - size_variants: {Array} (required)
  - size_variants_avai: {Array} (required)
  - size_count: {Interger} (required)
  - class: {String} a list class. (optional)
  - size_option_name: {String} (required)
  - size_option_index: {String} (required)

  Usage:
  {% render 'size-list', size_variants: size_variants, size_variants_avai: size_variants_avai %}
{%- endcomment -%}
{%- liquid 
  if settings.enable_size_limit
    assign size_maximum = settings.size_maximum
  else
    assign size_maximum = 9999
  endif 
-%} 

{% if settings.size_mode == "custom_size" %}
  {% unless product != blank and size_option_name != blank and size_option_index != blank and product.has_only_default_variant %}
    <fieldset class="hdt-text-center">
      <p class="hdt-text-center">Selecciona la talla</p>
      {%- for size in size_variants limit: size_maximum -%}
        {% assign option_position = forloop.index %}
        {%- liquid
          unless size_variants_avai contains size or settings.size_type == 'all'
            continue
          endunless
        -%}
        {% liquid
          # Find variant that matches this size option
          assign found_variant = product.variants | where: size_option_index, size | first
        %}
        {% if found_variant %}
          <size-atc variant-id="{{ found_variant.id }}">
            <input type="radio" class="single-option-selector-{{ section.id }} "
              {% comment %} {% if option.selected_value == value %} checked="checked"{% endif %} {% endcomment %}
              value="{{ size | escape }}"
              data-index="option{{option_position}}"
              name="{{ size_option_name | handleize }}"
              id="SingleOptionSelector-{{product.id}}-{{ forloop.index0 }}"
              {% if found_variant.available == false or found_variant.price == 0 %}
                disabled="disabled"
              {% endif %}
              >
          </size-atc>
          <label for="SingleOptionSelector-{{product.id}}-{{ forloop.index0 }}" data-value="{{ size | escape }}">
            {{size}}
          </label>
      {% endif %}
      {%- endfor -%}
    </fieldset>
  {% endunless %}
{% else %}
<div class="hdt-size-list {{ class }}">
  <div class="hdt-size-list-wrapper">
    {%- if settings.size_mode == 'size' -%}
      {%- for size in size_variants limit: size_maximum -%}
        {%- liquid
        unless size_variants_avai contains size or settings.size_type == 'all'
          continue
        endunless
        -%}
        <span class="hdt-size-list-item"{% unless size_variants_avai contains size %} unavailable{% endunless %}>{{ size | escape }}</span>
      {%- endfor -%}
        {%- if settings.enable_size_limit and size_count > settings.size_maximum -%}
          <a class="hdt-size-list-item" href="{{ product_url }}" aria-label="View product"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="12" viewBox="0 0 14 12" fill="none" aria-hidden="true" focusable="false"><path d="M8.75 11.25L7.525 9.98125L10.6312 6.875H0V5.125H10.6312L7.525 2.01875L8.75 0.75L14 6L8.75 11.25Z" fill="currentColor"/></svg></a>
        {%- endif -%}
    {%- else -%}
      <p class="hdt-size-count">{{- 'products.product.sizes_count' | t: count: size_count -}}</p>
    {%- endif -%}
  </div>
</div>
{% endif %}
