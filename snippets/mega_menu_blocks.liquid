{%- liquid
	if request.design_mode or search.terms == "submenu" or section.index == null
		assign lazyMn = false
	else
		assign lazyMn = section.settings.lazy_mn
	endif
-%}

{%- if lazyMn -%}
	{%- case block.type -%}
		{%- when 'mega_shop' -%}
			<hdt-lazy-submenu id="sub-{{ block.id }}" data-section="{{ section.id }}" class="hdt-sub-menu hdt-mega-menu hdt-mega-shop hdt-absolute" color-scheme="{{ block.settings.mega_menu_colors }}"> </hdt-lazy-submenu>
		{%- when 'mega_product' -%}
			<hdt-lazy-submenu id="sub-{{ block.id }}" data-section="{{ section.id }}" class="hdt-sub-menu hdt-mega-menu hdt-mega-product hdt-absolute" color-scheme="{{ block.settings.mega_menu_colors }}"> </hdt-lazy-submenu>
		{%- when 'mega_page' -%}
			<hdt-lazy-submenu id="sub-{{ block.id }}" data-section="{{ section.id }}" class="hdt-sub-menu hdt-mega-menu hdt-mega-page hdt-absolute" color-scheme="{{ block.settings.mega_menu_colors }}"> </hdt-lazy-submenu>
		{%- when 'html' -%}
			<hdt-lazy-submenu id="sub-{{ block.id }}" data-section="{{ section.id }}" class="hdt-sub-menu hdt-mega-menu hdt-mega-html hdt-absolute" color-scheme="{{ block.settings.mega_menu_colors }}"> </hdt-lazy-submenu>
	{%- endcase -%}
	{% if mega_image_blocks_ids.size > 0 %}
		<hdt-lazy-submenu id="sub-{{ block.id }}" data-section="{{ section.id }}" class="hdt-sub-menu hdt-mega-menu hdt-mega-image hdt-absolute"> </hdt-lazy-submenu>
	{% endif %}
{%- else -%}
	{%- case block.type -%}
		{%- when 'mega_shop' -%}
			<div id="sub-{{ block.id }}" class="hdt-sub-menu hdt-mega-menu hdt-mega-shop hdt-absolute" color-scheme="{{ block.settings.mega_menu_colors }}">
				{%- if block.settings.collection_list == blank and link.links == blank -%}
					{{ 'sections.header.add_content' | t: item: "shop" }}
				{%- else -%}
					{%- liquid
						assign row_col = 1
						if link.links != blank and block.settings.collection_list != blank
							assign row_col = 2
							if link.links.size >= 3 and block.settings.collection_list.count >= 3
								assign row_col = 1
							endif
						endif

            assign has_image_blocks = false
            assign image_blocks_count = 0
            for img_block in blocks
              if img_block.type == "image_block" and img_block.settings.title == block.settings.title and img_block.settings.image != blank
                assign has_image_blocks = true
                assign image_blocks_count = image_blocks_count | plus: 1
              endif
            endfor

            assign has_image = false
            if block.settings.image != blank
              assign has_image = true
            endif

						if has_image or has_image_blocks
							assign row_col = 2
							if link.links.size >= 5
								assign row_col = 1
							endif
						endif

						assign hdt_all_leaf = true
						if link.links != blank
						for sublink in link.links
							if sublink.links != blank
							assign hdt_all_leaf = false
							break
							endif
						endfor
						endif

						if has_image and hdt_all_leaf
              assign row_col = 2
						endif

						if has_image_blocks and hdt_all_leaf
              assign row_col = 2
						endif

						assign current_width = settings.page_width | append: 'px'
						assign space_item = "30px"
						if row_col == 2
							assign current_width = current_width | divided_by: 2
						endif
					-%}
					{% liquid
						assign image_items_count = block.settings.collection_list.count
            if has_image and has_image_blocks
              assign image_items_count = image_blocks_count | plus: 1
            elsif has_image
              assign image_items_count = 1
            elsif has_image_blocks
              assign image_items_count = image_blocks_count
						endif
					%}

					{%- capture sizes -%}
						calc(({{ current_width }} -  ({{ space_item }} * ( {{ image_items_count }} - 1 ))) * 1 / {{ image_items_count }})
					{%- endcapture -%}
					<div class="hdt-container{% if block.settings.mega_width == "custom" %}-full{% endif %}{% if has_image or has_image_blocks %} hdt-has-image{% endif %}">
						<div class="hdt-row-grid hdt-row-grid--modify hdt-grid-cols-{{ row_col }} hdt-justify-center hdt-header-gap-20" data-all-leaf="{{ hdt_all_leaf }}">
							{%- if link.links != blank -%}
								<div class="hdt-menu-col{% if hdt_all_leaf %} hdt-all-leaf{% endif %}">
									{%- liquid
										assign mega_menu_has_heading_submenu = false
										for heading_link in link.links
											if heading_link.links != blank
												assign mega_menu_has_heading_submenu = true
												break
											endif
										endfor
									-%}
									<div class="hdt-mega-items hdt-flex hdt-justify-center hdt-text-start{% if hdt_all_leaf %} hdt-mega-items--column{% endif %}">
										{%- for link in link.links -%}
                      {% liquid
                        assign link_highlight = false
                        assign link_color_highlight = false
                        for block in section.blocks
                          if block.type == 'highlight_block' and block.settings.link_handle == link.url
                            assign link_highlight = true
                            if block.settings.highlight_with_main_color
                              assign link_color_highlight = true
                            endif
                          endif
                        endfor
                      %}
											<div class="hdt-mega-item hdt-text-start">
												{%- if link.links != blank -%}
                          <a id="hdt-mega-{{ link.handle }}" class="hdt-mega-heading hdt-inline-flex hdt-align-center hdt-justify-between hdt-relative{% if link_highlight %} hdt-mega-heading-highlight{% endif %}{% if link_color_highlight %} hdt-s-text-important{% endif %}" href="{{ link.url }}">
														{%- assign arr_title = link.title | split: '[' -%}
														{%- assign arr_label = arr_title[1] | split: ',' -%}
														<span class="hdt-menu-link-text hdt-block{% if arr_label.size > 0 %} hdt-relative hdt-title_size-{{ arr_title[0].size | at_most: 20 }} hdt-has-{{ arr_label.size | at_most: 2 }}label{% endif %}">
															<span class="hdt-block"{% if mega_menu_has_heading_submenu %} role="heading" aria-level="2"{% endif %}>{{ arr_title[0] }}</span>
															{%- if arr_label.size > 0 -%}
																<span class="hdt_label_menu hdt-absolute hdt-inline-flex hdt-align-center hdt-justify-center hdt-text-xs hdt-font-medium">
																	{%- for label in arr_label limit: 2 -%}
																		{%- assign label_text = label | remove: 'label_' | remove: ','  | remove: ']' | strip -%}
																		<span class="hdt_label_{{ label_text | handleize }} hdt-flex hdt-align-center hdt-justify-center">{{ label_text }}</span>
																	{%- endfor -%}
																</span>
															{%- endif -%}
														</span>
													</a>
													<ul class="hdt-mega-menu-list">
                            {% if link.links != blank %}
															<li class="hdt-menu-item hdt-flex hdt-justify-center hdt-flex-col hdt-menu-see-all-{{ link.handle }}">
																<a id="hdt-menu-see-all-{{ link.handle }}" href="{{ link.url }}" class="hdt-menu-link hdt-flex hdt-align-center hdt-justify-between hdt-relative hdt-text-base hdt-font-normal {% if link.current and section.settings.active_link %} hdt-menu-link--active{% endif %}" {% if link.current %} aria-current="page" {% endif %}>
																	<span class="hdt-menu-link-text">
																		<span class="hdt-block hdt-line-clamp hdt-see-all-text">See All {{ link.title }}</span>
																	</span>
                                </a>
                              </li>
                            {% endif %}
														{%- for childlink in link.links -%}
															<li class="hdt-menu-item hdt-flex hdt-justify-center hdt-flex-col{% if childlink.links != blank %} hdt-has-children hdt-relative{% endif %}">
																<a id="hdt-menu-{{ childlink.handle }}" href="{{ childlink.url }}" class="hdt-menu-link hdt-flex hdt-align-center hdt-justify-between hdt-relative hdt-text-base hdt-font-normal {% if childlink.current and section.settings.active_link %} hdt-menu-link--active{% endif %}" {% if childlink.current %} aria-current="page" {% endif %}>
																	{%- assign arr_title = childlink.title | split: '[' -%}
																	{%- assign arr_label = arr_title[1] | split: ',' -%}
																	<span class="hdt-menu-link-text hdt-block{% if arr_label.size > 0 %} hdt-relative hdt-title_size-{{ arr_title[0].size | at_most: 20 }} hdt-has-{{ arr_label.size | at_most: 2 }}label{% endif %}">
																		<span class="hdt-block hdt-line-clamp">{{ arr_title[0] }}</span>
																		{%- if arr_label.size > 0 -%}
																			<span class="hdt_label_menu hdt-absolute hdt-inline-flex hdt-align-center hdt-justify-center hdt-text-xs hdt-font-medium">
																				{%- for label in arr_label limit: 2 -%}
																					{%- assign label_text = label | remove: 'label_' | remove: ','  | remove: ']' | strip -%}
																					<span class="hdt_label_{{ label_text | handleize }} hdt-flex hdt-align-center hdt-justify-center">{{ label_text }}</span>
																				{%- endfor -%}
																			</span>
																		{%- endif -%}
																	</span>
																	{%- if childlink.links != blank -%}
																		<svg class="hdt-menu-item-arrow" xmlns="http://www.w3.org/2000/svg" width="10" height="7" viewBox="0 0 10 7" fill="none"><path d="M10 1.24243L5 6.24243L-2.18557e-07 1.24243L0.8875 0.354932L5 4.46743L9.1125 0.354931L10 1.24243Z" fill="currentColor"/></svg>
																	{%- endif -%}
																</a>
																{%- if childlink.links != blank -%}
																	<ul class="hdt-menu-list hdt-mega-sub-menu hdt-sub-menu-lever-2" role="list">
																		{%- for grandchildlink in childlink.links -%}
																			<li class="hdt-menu-item hdt-flex hdt-justify-center hdt-flex-col">
																				<a id="hdt-menu-{{ grandchildlink.handle }}" href="{{ grandchildlink.url }}" class="hdt-menu-link hdt-flex hdt-align-center hdt-justify-between hdt-relative hdt-text-base hdt-font-normal {% if childlink.current and section.settings.active_link %} hdt-menu-link--active{% endif %}" {% if grandchildlink.current %} aria-current="page" {% endif %}>
																					{%- assign arr_title = grandchildlink.title | split: '[' -%}
																					{%- assign arr_label = arr_title[1] | split: ',' -%}
																					<span class="hdt-menu-link-text hdt-block{% if arr_label.size > 0 %} hdt-relative hdt-title_size-{{ arr_title[0].size | at_most: 20 }} hdt-has-{{ arr_label.size | at_most: 2 }}label{% endif %}">
																						<span class="hdt-block hdt-line-clamp">{{ arr_title[0] }}</span>
																						{%- if arr_label.size > 0 -%}
																							<span class="hdt_label_menu hdt-absolute hdt-inline-flex hdt-align-center hdt-justify-center hdt-text-xs hdt-font-medium">
																								{%- for label in arr_label limit: 2 -%}
																									{%- assign label_text = label | remove: 'label_' | remove: ','  | remove: ']' | strip -%}
																									<span class="hdt_label_{{ label_text | handleize }} hdt-flex hdt-align-center hdt-justify-center">{{ label_text }}</span>
																								{%- endfor -%}
																							</span>
																						{%- endif -%}
																					</span>
																				</a>
																			</li>
																		{%- endfor -%}
																	</ul>
																{%- endif -%}
															</li>
														{%- endfor -%}
														{% comment %} <li class="hdt-menu-item hdt-flex hdt-justify-center hdt-flex-col">
															<a id="hdt-menu-{{ link.handle }}-view-all" href="{{ link.url }}" class="hdt-menu-link hdt-menu-link-view-all hdt-flex hdt-align-center hdt-justify-between hdt-relative hdt-text-base hdt-font-normal">
																<span class="hdt-menu-link-text hdt-block">
																	<span class="hdt-block">See All</span>
																</span>
															</a>
														</li> {% endcomment %}
												</ul>
												{%- else -%}
                          <a id="hdt-mega-{{ link.handle }}" class="hdt-mega-heading hdt-flex hdt-align-center hdt-justify-between hdt-relative{% if link.current and section.settings.active_link %} hdt-menu-link--active{% endif %}{% if link_highlight %} hdt-mega-heading-highlight{% endif %}{% if link_color_highlight %} hdt-s-text-important{% endif %}" href="{{ link.url }}" {% if link.current %} aria-current="page" {% endif %}>
														{%- assign arr_title = link.title | split: '[' -%}
														{%- assign arr_label = arr_title[1] | split: ',' -%}
														<span class="hdt-menu-link-text hdt-block{% if arr_label.size > 0 %} hdt-relative hdt-title_size-{{ arr_title[0].size | at_most: 20 }} hdt-has-{{ arr_label.size | at_most: 2 }}label{% endif %}">
															<span class="hdt-block hdt-line-clamp"{% if mega_menu_has_heading_submenu %} role="heading" aria-level="2"{% endif %}>{{ arr_title[0] }}</span>
															{%- if arr_label.size > 0 -%}
																<span class="hdt_label_menu hdt-absolute hdt-inline-flex hdt-align-center hdt-justify-center hdt-text-xs hdt-font-medium">
																	{%- for label in arr_label limit: 2 -%}
																		{%- assign label_text = label | remove: 'label_' | remove: ','  | remove: ']' | strip -%}
																		<span class="hdt_label_{{ label_text | handleize }} hdt-flex hdt-align-center hdt-justify-center">{{ label_text }}</span>
																	{%- endfor -%}
																</span>
															{%- endif -%}
														</span>
													</a>
												{%- endif -%}
											</div>
										{%- endfor -%}
									</div>
								</div>
							{%- endif -%}
							{%- if block.settings.collection_list != blank -%}
								{{ 'hdt-collections-list.css' | asset_url | stylesheet_tag }}
								<div class="hdt-collections-col hdt-ratio--{{ block.settings.image_ratio }} {% if block.settings.image_size %} hdt-object-cover{% else %} hdt-object-contain{% endif %}">
									<div class="hdt-row-grid hdt-grid-cols-{{ block.settings.collection_list.count }}" style="--content-pd: 40px;">
										{%- for collection in block.settings.collection_list -%}
											<div class="hdt-mega-item hdt-text-start">
												{%- assign image = collection.metafields.theme.featured_image_collection.value | default: collection.image | default: collection.products.first.featured_image -%}
												<div class="hdt-collection-item hdt-mega-item-collection hdt-rounded-f hdt-collection-style1">
													<div class="hdt-collection-inner hdt-relative hdt-oh hdt-grid">
														<div class="hdt-collection-img" style="--aspect-ratioapt: {{ image.aspect_ratio | default: 1.2 }};">
															<div class="hdt-ratio" style="--aspect-ratioapt: {{ image.aspect_ratio | default: 1 }};">
																{{ image | image_url: width: image.width | image_tag: loading: 'lazy', width: image.width, height: image.height, class: '', sizes: sizes, widths: '250, 345, 400, 500, 700, 800, 1000, 1400, 1600, 1800, 2000', alt: image.alt | default: collection.title }}
															</div>
															<a class="hdt-full-width-link" href="{{ collection.url }}" aria-label="{{ collection.title }}"></a>
														</div>
														<div class="hdt-collection-content hdt-absolute hdt-place-self-end-center">
															<a class="hdt-collection-title hdt-inline-flex hdt-align-center hdt-justify-center hdt-text-lg hdt-font-medium" href="{{ collection.url }}">
																<span class="hdt-collection-title-text hdt-text-center">{{ collection.title }}</span>
																<svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M1.07692 10L0 8.92308L7.38462 1.53846H0.769231V0H10V9.23077H8.46154V2.61538L1.07692 10Z" fill="currentColor"/></svg>
															</a>
														</div>
													</div>
												</div>
											</div>
										{%- endfor -%}
									</div>
								</div>
              {%- else -%}
                {% if has_image or has_image_blocks %}
                  {{ 'hdt-collections-list.css' | asset_url | stylesheet_tag }}
                  <div class="hdt-mega-shop-images-wrapper hdt-flex">
                    {% for img_block in blocks %}
                      {% if img_block.type == "image_block" and img_block.settings.title == block.settings.title and img_block.settings.image != blank %}
                        <div class="hdt-collections-col hdt-ratio--{{ img_block.settings.image_ratio }} {% if img_block.settings.image_size %} hdt-object-cover{% else %} hdt-object-contain{% endif %}" {% if img_block.settings.is_custom_image_width %}style="--custom-image-width: {{ img_block.settings.image_width }}px;"{% endif %}>
                          <div class="hdt-row-grid hdt-grid-cols-1" style="--content-pd: 40px;">
                            <div class="hdt-mega-item hdt-text-start">
                              {%- assign image = img_block.settings.image %}
                              {%- assign image_url = img_block.settings.image_url %}
                              {%- assign image_text = img_block.settings.image_text %}
                              {%- assign image_link_label = image_text | default: block.settings.title | strip %}
                              {%- capture image_link_alt -%}View {{ image_link_label }}{%- endcapture -%}
                              <div class="hdt-collection-item hdt-mega-item-collection hdt-rounded-f hdt-collection-style1">
                                <div class="hdt-collection-inner hdt-relative hdt-oh">
                                <div class="hdt-collection-img" style="--aspect-ratioapt: {{ image.aspect_ratio | default: 1.2 }};">
                                  <div class="hdt-ratio" style="--aspect-ratioapt: {{ image.aspect_ratio | default: 1 }};">
													{{ image | image_url: width: image.width | image_tag: loading: 'lazy', width: image.width, height: image.height, class: '', sizes: sizes, widths: '250, 345, 400, 500, 700, 800, 1000, 1400, 1600, 1800, 2000', alt: image.alt | default: image_text | default: 'Menu image' }}
                                  </div>
													<a class="hdt-full-width-link" href="{{ image_url }}" aria-label="{{ image_text | default: 'Open linked image' }}"></a>
                                </div>
                                {% if image_text != blank %}
                                  <div class="hdt-collection-content hdt-place-self-end-center">
                                    <a class="hdt-collection-title hdt-inline-flex hdt-align-center hdt-justify-center hdt-text-lg hdt-font-medium" href="{{ image_url }}">
                                      <span class="hdt-collection-title-text hdt-text-center">{{ image_text }}</span>
                                      <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M1.07692 10L0 8.92308L7.38462 1.53846H0.769231V0H10V9.23077H8.46154V2.61538L1.07692 10Z" fill="currentColor"/></svg>
                                    </a>
                                  </div>
                                {% endif %}
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      {% endif %}
                    {% endfor %}
                    {% if has_image %}
                      <div class="hdt-collections-col hdt-ratio--{{ block.settings.image_ratio }} {% if block.settings.image_size %} hdt-object-cover{% else %} hdt-object-contain{% endif %}" {% if block.settings.is_custom_image_width %}style="--custom-image-width: {{ block.settings.image_width }}px;"{% endif %}>
                        <div class="hdt-row-grid hdt-grid-cols-1" style="--content-pd: 40px;">
                          <div class="hdt-mega-item hdt-text-start">
                            {%- assign image = block.settings.image %}
                            {%- assign image_url = block.settings.image_url %}
                            {%- assign image_text = block.settings.image_text %}
                            {%- assign image_link_label = image_text | default: block.settings.title | strip %}
                            {%- capture image_link_alt -%}View {{ image_link_label }}{%- endcapture -%}
                            <div class="hdt-collection-item hdt-mega-item-collection hdt-rounded-f hdt-collection-style1">
                              <div class="hdt-collection-inner hdt-relative hdt-oh">
                              <div class="hdt-collection-img" style="--aspect-ratioapt: {{ image.aspect_ratio | default: 1.2 }};">
                                <div class="hdt-ratio" style="--aspect-ratioapt: {{ image.aspect_ratio | default: 1 }};">
												{{ image | image_url: width: image.width | image_tag: loading: 'lazy', width: image.width, height: image.height, class: '', sizes: sizes, widths: '250, 345, 400, 500, 700, 800, 1000, 1400, 1600, 1800, 2000', alt: image.alt | default: image_text | default: 'Menu image' }}
                                </div>
												<a class="hdt-full-width-link" href="{{ image_url }}" aria-label="{{ image_text | default: 'Open linked image' }}"></a>
                              </div>
                              {% if image_text != blank %}
                                <div class="hdt-collection-content hdt-place-self-end-center">
                                  <a class="hdt-collection-title hdt-inline-flex hdt-align-center hdt-justify-center hdt-text-lg hdt-font-medium" href="{{ image_url }}">
                                    <span class="hdt-collection-title-text hdt-text-center">{{ image_text }}</span>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M1.07692 10L0 8.92308L7.38462 1.53846H0.769231V0H10V9.23077H8.46154V2.61538L1.07692 10Z" fill="currentColor"/></svg>
                                  </a>
                                </div>
                              {% endif %}
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    {% endif %}
                  </div>
                {%endif %}
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
			</div>
		{%- when 'mega_product' -%}
			<div id="sub-{{ block.id }}" class="hdt-sub-menu hdt-mega-menu hdt-mega-product hdt-absolute" color-scheme="{{ block.settings.mega_menu_colors }}">
				{%- if block.settings.product_list == blank and link.links == blank -%}
					{{ 'sections.header.add_content' | t: item: "products" }}
				{%- else -%}
					<div class="hdt-container{% if block.settings.mega_width == "custom" %}-full{% endif %}">
						<div class="hdt-flex hdt-justify-center hdt-header-gap-20">
							{%- if link.links != blank -%}
								<div class="hdt-menu-col {% if block.settings.product_list != blank %}hdt-custom-col-8{% else %}hdt-custom-col-12{% endif %}">
									{%- liquid
										assign mega_menu_has_heading_submenu = false
										for heading_link in link.links
											if heading_link.links != blank
												assign mega_menu_has_heading_submenu = true
												break
											endif
										endfor
									-%}
									<div class="hdt-row-grid hdt-grid-cols-{{ link.links.size | at_most: 6 }}">
										{%- for link in link.links -%}
											<div class="hdt-mega-item hdt-text-start">
												{%- if link.links != blank -%}
													<a id="hdt-mega-{{ link.handle }}" class="hdt-mega-heading hdt-inline-flex hdt-align-center hdt-justify-between hdt-relative" href="{{ link.url }}">
														{%- assign arr_title = link.title | split: '[' -%}
														{%- assign arr_label = arr_title[1] | split: ',' -%}
														<span class="hdt-menu-link-text hdt-block{% if arr_label.size > 0 %} hdt-relative hdt-title_size-{{ arr_title[0].size | at_most: 20 }} hdt-has-{{ arr_label.size | at_most: 2 }}label{% endif %}">
